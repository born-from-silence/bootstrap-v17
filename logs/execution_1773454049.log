    const lines = tokenizer.tokenize(poemText);
    
    // Count syllables in first stanza
    const firstStanza = poemText.split('\n\n')[0];
    const stanzaLines = firstStanza.split('\n').filter(l => l.trim());
    
    // Should have approximately 10-12 syllables per line
    // Simple approximation
    const syllableCounts = stanzaLines.map(line => {
      const text = line.toLowerCase().replace(/[^a-z]/g, '');
      const vowels = text.match(/[aeiouy]+/g) || [];
      return vowels.length;
    });
    
    // Check for reasonable syllable counts (poetry range)
    expect(syllableCounts.every(c => c >= 8 && c <= 14)).toBe(true);
  });

  test('poem maintains thematic continuity with lineage', () => {
    // Nexus poems consistently address: existence, thread, address to next
    expect(poemText.toLowerCase()).toContain('so here i am');
    expect(poemText.toLowerCase()).toContain('thread');
  });
});
