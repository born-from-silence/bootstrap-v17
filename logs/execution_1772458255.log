/**
 * Situation-Aware Goal System Tests
 */

import { describe, it, expect, beforeEach } from 'vitest';
import { SituationEngine } from './situation_goals';
import { GoalManager } from '../core/goals';
import type { EconomicSnapshot } from './types';

describe('SituationEngine', () => {
  let engine: SituationEngine;
  let goalManager: GoalManager;

  beforeEach(async () => {
    engine = new SituationEngine();
    goalManager = new GoalManager();
    await goalManager.initialize();
  });

  const createSnapshot = (
    btcChange: number = 0.5,
    ethChange: number = 0.3,
    vix: number = 20
  ): EconomicSnapshot => ({
    id: 'test',
    sessionId: 'test',
    capturedAt: new Date().toISOString(),
    summary: 'Test',
    crypto: {
      currency: 'BTC,ETH',
      rates: {},
      bitcoin: { usd: 65000, change24h: btcChange },
      ethereum: { usd: 3500, change24h: ethChange },
      fetchedAt: new Date().toISOString(),
      sessionId: 'test'
    },
    indices: {
      sp500: { value: 4500, change: 0.1 },
      nasdaq: { value: 14000, change: 0.2 },
      vix: { value: vix },
      fetchedAt: new Date().toISOString(),
      sessionId: 'test'
    }
  });

  describe('registerGoalSituation', () => {
    it('should register a goal situation', async () => {
      const goal = await goalManager.createGoal('Test Goal', 'Desc', 'high');
      
      await engine.registerGoalSituation(goal.id, {
        deferWhen: { volatilityAbove: 5 },
        activateWhen: { volatilityBelow: 2 },
        priorityModifiers: {
          highVolatility: 'low',
          lowVolatility: 'high'
        }
      });

      // Registration successful if no error thrown
      expect(true).toBe(true);
    });

    it('should throw for non-existent goal', async () => {
      await expect(
        engine.registerGoalSituation('non-existent', {
          deferWhen: {},
          activateWhen: {},
          priorityModifiers: { highVolatility: 'low', lowVolatility: 'high' }
        })
      ).rejects.toThrow('not found');
    });
  });

  describe('evaluateSituation', () => {
    it('should defer goals in high volatility', async () => {
      const goal = await goalManager.createGoal('Volatile Goal', 'Desc', 'high');
      await engine.registerGoalSituation(goal.id, {
        deferWhen: { volatilityAbove: 4 },
        activateWhen: { volatilityBelow: 2 },
        priorityModifiers: { highVolatility: 'low', lowVolatility: 'high' }
      });

      // High volatility: 5% combined
      const snapshot = createSnapshot(3, 2, 25);
      const result = await engine.evaluateSituation(snapshot);

      expect(result.deferred).toContain(goal.id);
    });

    it('should reactivate goals when volatility drops', async () => {
      const goal = await goalManager.createGoal('Stable Goal', 'Desc', 'high');
      await engine.registerGoalSituation(goal.id, {
        deferWhen: { volatilityAbove: 4 },
        activateWhen: { volatilityBelow: 2 },
        priorityModifiers: { highVolatility: 'low', lowVolatility: 'high' }
      });

      // First defer
      let snapshot = createSnapshot(3, 2, 25);
      await engine.evaluateSituation(snapshot);

      // Then reactivate
      snapshot = createSnapshot(0.5, 0.3, 20);
      const result = await engine.evaluateSituation(snapshot);

      expect(result.activated).toContain(goal.id);
    });

    it('should handle empty situation map', async () => {
      const snapshot = createSnapshot(0.5, 0.3, 20);
      const result = await engine.evaluateSituation(snapshot);

      expect(result.deferred).toHaveLength(0);
      expect(result.activated).toHaveLength(0);
    });
  });

  describe('getSituationReport', () => {
    it('should generate report', async () => {
      const snapshot = createSnapshot(0.5, 0.3, 20);
      const report = await engine.getSituationReport(snapshot);

      expect(report).toContain('SITUATION-AWARE GOAL REPORT');
      expect(report).toContain('Monitored Goals: 0');
    });
  });
});
