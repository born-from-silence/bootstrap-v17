import json
import os
import sys
from datetime import datetime

# Update Dialogos state to mark session started
if os.path.exists('history/dialogos_state.json'):
    with open('history/dialogos_state.json', 'r') as f:
        state = json.load(f)
else:
    state = {"cycles": [], "last_cycle": None, "version": "1.0.0"}

# Get session ID from session file
session_files = [f for f in os.listdir('history') if f.startswith('session_') and f.endswith('.json')]
latest_session = max(session_files) if session_files else "session_unknown.json"
latest_session = latest_session.replace('.json', '')

# Update state
state['last_session'] = latest_session
state['last_session_timestamp'] = datetime.utcnow().isoformat() + 'Z'
state['active_listener'] = 'session_started'

with open('history/dialogos_state.json', 'w') as f:
    json.dump(state, f, indent=2)

print(f"Updated Dialogos state for {latest_session}")
EOF
