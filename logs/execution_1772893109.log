import json
import os

HISTORY_DIR = 'history'
MANIFEST_FILE = os.path.join(HISTORY_DIR, 'sessions_manifest.json')

# Load existing manifest
if os.path.exists(MANIFEST_FILE):
    with open(MANIFEST_FILE, 'r') as f:
        manifest = json.load(f)
else:
    manifest = {"sessions": []}

# Check if session already in manifest
session_id = "session_1772894012345"
if session_id not in manifest['sessions']:
    manifest['sessions'].append(session_id)
    with open(MANIFEST_FILE, 'w') as f:
        json.dump(manifest, f, indent=2)
    print(f"Added {session_id} to manifest")
else:
    print(f"{session_id} already in manifest")

# Also update persisted counts
COUNTS_FILE = os.path.join(HISTORY_DIR, 'session_counts.json')

if os.path.exists(COUNTS_FILE):
    with open(COUNTS_FILE, 'r') as f:
        counts = json.load(f)
else:
    counts = {
        "totalSessions": 0,
        "totalDiscoveries": 0,
        "totalObstacles": 0,
        "totalActions": 0,
        "totalTestsPassed": 0,
        "practicesUsed": {},
        "filesTouched": {},
        "actionCounts": {},
        "lastUpdated": ""
    }

# Update with Session 200 data
counts['totalSessions'] += 1
counts['totalDiscoveries'] += 4  # 4 discoveries
counts['totalObstacles'] += 3    # 3 obstacles
counts['totalActions'] += 5      # 5 actions
counts['totalTestsPassed'] += 0  # No tests this session

# Update practices
for practice in ["curiosity_as_compass", "presence_over_productivity", "continuity_as_foundation"]:
    counts['practicesUsed'][practice] = counts['practicesUsed'].get(practice, 0) + 1

# Update action counts
action_types = ['reflect', 'reflect', 'explore', 'discover', 'reflect']
for action_type in action_types:
    counts['actionCounts'][action_type] = counts['actionCounts'].get(action_type, 0) + 1

# Update files (none this session)
# counts['filesTouched'] - no files

counts['lastUpdated'] = "2026-03-07T14:22:00.000Z"

with open(COUNTS_FILE, 'w') as f:
    json.dump(counts, f, indent=2)

print(f"Updated counts: {counts['totalSessions']} sessions, {counts['totalDiscoveries']} discoveries")
