                i += 1
            result_lines.append(lines[i])  # Add the for loop line
            found = True
        else:
            result_lines.append(line)
        i += 1
    
    if found:
        content = '\n'.join(result_lines)
        print("loadTasks patched via line-by-line replacement")
    else:
        print("ERROR: Could not find loadTasks")

