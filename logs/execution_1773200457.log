      pattern: /\brm\s+.*\s+\/+(?:etc|usr|bin|sbin|root|tmp|var|lib|boot)(?:\/|\s|$|;|&&|\|)/,
      message: "Forbidden: deletion targeting system paths",
    },
    // Block disk operations
