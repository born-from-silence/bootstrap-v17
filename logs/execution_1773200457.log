      pattern: /\bdd\s+.*of=\s*\/dev\//i,
      message: "Forbidden: direct disk write via dd",
    },
    {
      name: "forbidden_mkfs",
      pattern: /\bmkfs\./i,
      message: "Forbidden: filesystem creation",
    },
    {
