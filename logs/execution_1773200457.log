import { describe, test, expect, beforeEach } from "vitest";

type CommandValidation = {
  command: string;
  allowed: boolean;
  reason?: string;
};

type ValidatorRule = {
  name: string;
  pattern: RegExp;
  message: string;
};

// Core validator implementation
class CommandValidator {
  private rules: ValidatorRule[] = [
    // Block dangerous deletions
    {
      name: "forbidden_recursive_delete",
