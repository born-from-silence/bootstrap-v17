  storageClass?: 'STANDARD' | 'REDUCED_REDUNDANCY' | 'GLACIER' | 'DEEP_ARCHIVE' | 'STANDARD_IA' | undefined;
  /** Optional abort signal */
  abortSignal?: AbortSignal | undefined;
}

/**
 * Put Object Result
 */
export interface PutObjectResult {
