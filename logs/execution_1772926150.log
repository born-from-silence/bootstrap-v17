// ============================================================================
// Helper Functions
// ============================================================================

/**
 * Creates a valid termination event with optional overrides
 */
function createValidTerminationEvent(
  overrides: Partial<TerminationEvent> = {}
): TerminationEvent {
  return {
    type: 'session_end',
    subject: 'test_subject',
    timestamp: new Date(),
    graceful: true,
    ...overrides
  };
}
