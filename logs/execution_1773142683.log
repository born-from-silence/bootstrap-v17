        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-cyan));
            border: none;
            color: #1a1a2e;
            font-weight: 500;
        }

        .btn-primary:hover {
            box-shadow: 0 4px 25px rgba(167, 139, 250, 0.4);
        }

        .btn-danger {
            background: linear-gradient(135deg, var(--accent-coral), #ff8e8e);
            border: none;
            color: white;
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        /* Progress ring */
        .progress-container {
            position: relative;
