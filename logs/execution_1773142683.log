        }

        .toast-icon.error {
            background: rgba(255, 107, 107, 0.2);
            color: var(--accent-coral);
        }

        /* Responsive */
        @media (max-width: 480px) {
            .time-value {
                font-size: 2.5rem;
            }
            .time-separator {
                font-size: 2rem;
            }
