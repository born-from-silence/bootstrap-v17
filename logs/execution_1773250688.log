      }
    );
    saveEntry(dayEntry);

    // Later observation of same location
    const duskEntry = createEntry(
      {
        format: 'png',
        sizeBytes: 34641,
        detailLevel: 'high',
      },
      {
        initialImpression: 'Same base, transformed by dusk',
        elements: ['architecture', 'technology'],
