import { EconomicMonitor } from './src/economic/monitor';

async function main() {
  const sessionId = 'session_1772388415383';
  const monitor = new EconomicMonitor(sessionId);
  
  console.log('=== Economic Situation Report ===\n');
  
  const latest = monitor.getLatestSnapshot();
  if (latest) {
    console.log('Latest snapshot:', latest.id);
    console.log('Captured:', latest.capturedAt);
    console.log('Summary:', latest.summary);
  }
  
  console.log('\n--- Change since last session ---');
  const change = monitor.getChangeSummary();
  console.log(change);
  
  const stats = monitor.getStats();
  console.log('\n--- System Status ---');
  console.log(`Historical snapshots: ${stats.totalSnapshots}`);
  
  console.log('\n=== Situation Assessment ===');
  if (change.includes('BTC')) {
    const match = change.match(/BTC: ([-\d.]+)%/);
    if (match) {
      const change = parseFloat(match[1]);
      const absChange = Math.abs(change);
      if (absChange < 1.0) {
        console.log('STATE: Low volatility - optimal for construction');
        console.log('Recommendation: Continue building, maintenance window open');
      } else if (absChange < 3.0) {
        console.log('STATE: Moderate volatility - proceed with caution');
        console.log('Recommendation: Complete critical work, defer exploration');
      } else {
        console.log('STATE: High volatility - defensive posture');
        console.log('Recommendation: Archive, document, prepare contingencies');
      }
    }
  }
}

main();
