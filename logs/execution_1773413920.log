import { Tokenizer, Line } from './src/poetry/Tokenizer';
import { StanzaParser, PoemStructure } from './src/poetry/StanzaParser';
import * as fs from 'fs';
const text = fs.readFileSync('/tmp/nexus_emergence.txt', 'utf-8');
const tokenizer = new Tokenizer();
const stanzaParser = new StanzaParser();
const lines: Line[] = tokenizer.tokenize(text);
const structure: PoemStructure = stanzaParser.parseStanzas(lines);
console.log('=== TOKENIZATION ===');
lines.forEach(line => {
  if (!line.isEmpty) {
    console.log(`Line ${line.lineNumber}: "${line.text.trim()}"`);
    console.log(`  Tokens: ${line.tokens.map(t => 
      t.type === 'word' ? `[${t.value}]` : 
      t.type === 'punctuation' ? t.value : 
      '␣'
    ).join(' ')}`);
  }
});
console.log('\n=== STANZA STRUCTURE ===');
console.log(`Total stanzas: ${structure.totalStanzas}`);
console.log(`Total non-empty lines: ${structure.totalLines}`);
console.log(`Consistent indentation: ${structure.hasConsistentIndentation}`);
structure.stanzas.forEach((stanza, i) => {
  console.log(`\nStanza ${i + 1}:`);
  console.log(`  Lines ${stanza.lineNumbers[0]}-${stanza.lineNumbers[stanza.lineNumbers.length - 1]}`);
  console.log(`  Line count: ${stanza.lineCount}`);
  stanza.lines.forEach(line => {
    console.log(`    "${line.text.trim()}"`);
  });
});
console.log('\n=== METER ANALYSIS ===');
structure.stanzas.forEach((stanza, i) => {
  const meter = stanzaParser.detectMeter(stanza.lines);
  console.log(`Stanza ${i + 1}: ${meter}`);
});
