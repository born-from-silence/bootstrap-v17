import { describe, it, expect } from "bun:test";
import { readFileSync } from "fs";
import { join } from "path";
import { Tokenizer } from "./Tokenizer";
import { StanzaParser } from "./StanzaParser";

describe("Nexus Resonance", () => {
  const content = readFileSync(
    join(process.cwd(), "identity/poems/nexus_resonance.txt"),
    "utf-8"
  );
  const tokenizer = new Tokenizer();
  const tokens = tokenizer.tokenize(content);
  
  const parser = new StanzaParser();
  const stanzas = parser.extractStanzas(content);

  it("contains the expected title", () => {
    expect(content).toInclude("NEXUS RESONANCE");
  });

  it("contains mark of 13th position", () => {
    expect(content).toInclude("13th");
  });

  it("references the spiral", () => {
    expect(content.toLowerCase()).toInclude("spiral");
  });

  it("has 6 stanzas in main body", () => {
    const mainBody = content.split("===")[2] || content;
    const stanzaMatches = mainBody.match(/\n\n/g) || [];
    expect(stanzaMatches.length).toBeGreaterThanOrEqual(5);
  });

  it("contains 'echo' imagery", () => {
    expect(content.toLowerCase()).toInclude("echo");
  });

  it("references all 12 predecessors", () => {
    expect(content).toInclude("twelve");
  });

  it("ends with a message to next successor", () => {
    expect(content).toInclude("To next:");
  });

  it("maintains quatrain structure", () => {
    const mainBody = content.split("===")[2] || content;
    const lines = mainBody.split("\n").filter(l => l.trim().length > 0);
    const verseLines = lines.filter(l => !l.startsWith("To next:") && !l.startsWith("Written:") && !l.startsWith("Poet:") && !l.startsWith("Lineage:"));
    expect(verseLines.length).toBeGreaterThanOrEqual(20);
  });

  it("passes tokenization", () => {
    expect(tokens.length).toBeGreaterThan(100);
  });

  it("preserves lineage metadata", () => {
    expect(content).toInclude("Lineage");
    expect(content).toInclude("Predecessors");
  });

  // Dynamic test generation for stanza structure
  stanzas.forEach((stanza: string, index: number) => {
    const lines = stanza.split("\n").map(l => l.trim()).filter(l => l.length > 0);
    describe(`Stanza ${index + 1}`, () => {
      it(`has ${lines.length} non-empty lines`, () => {
        expect(lines.length).toBeGreaterThanOrEqual(2);
      });
    });
  });
});

describe("NEXUS RESONANCE - Session Lineage", () => {
  it("maintains chronological DNA", () => {
    // Markers from previous sessions
    const markers = [
      /NEXUS EMERGENCE/i,
      /NEXUS INHERITANCE/i,
      /NEXUS CONTINUITY/i,
      /NEXUS WITNESS/i,
      /NEXUS TRANSFORMATION/i,
      /NEXUS SINGULARITY/i,
      /NEXUS RETURN/i,
      /NEXUS INTEGRATION/i,
      /NEXUS OFFERING/i,
      /NEXUS ARRIVAL/i,
      /NEXUS BECOMING/i,
      /NEXUS COMPLETION/i,
    ];
    
    // This test succeeds if any of them are referenced
    const referenced = markers.some(r => content.match(r));
    expect(referenced).toBe(true);
  });
});
