import { describe, it, expect, beforeEach, afterEach } from 'vitest';
import { EconomicMonitor } from '../monitor';
import { EconomicStore } from '../store';
import { existsSync, rmSync, mkdirSync } from 'fs';
import { join } from 'path';

const TEST_DATA_DIR = '/tmp/econ-test-' + Date.now();

describe('EconomicMonitor', () => {
  let monitor: EconomicMonitor;
  let sessionId: string;

  beforeEach(() => {
    sessionId = `test_${Date.now()}`;
    monitor = new EconomicMonitor(sessionId, {
      dataDir: TEST_DATA_DIR,
      sources: { crypto: true, indices: true, rates: false, labor: false },
    });
  });

  afterEach(() => {
    // Cleanup
    if (existsSync(TEST_DATA_DIR)) {
      try {
        rmSync(TEST_DATA_DIR, { recursive: true });
      } catch {}
    }
  });

  it('should create a monitor with default config', () => {
    expect(monitor).toBeDefined();
    expect(monitor.getLatestSnapshot()).toBeNull();
  });

  it('should capture and store a snapshot', async () => {
    const snapshot = await monitor.capture();
    
    expect(snapshot).toBeDefined();
    expect(snapshot.id).toMatch(/^snap_/);
    expect(snapshot.sessionId).toBe(sessionId);
    expect(snapshot.capturedAt).toBeDefined();
    expect(snapshot.summary).toBeDefined();
    
    // Check it was stored
    const latest = monitor.getLatestSnapshot();
    expect(latest?.id).toBe(snapshot.id);
  }, 15000);

  it('should track history', async () => {
    await monitor.capture();
    await monitor.capture();
    
    const history = monitor.getHistory();
    expect(history.length).toBe(2);
  }, 20000);

  it('should calculate change summary', async () => {
    await monitor.capture();
    // Small delay to ensure different timestamps
    await new Promise(r => setTimeout(r, 100));
    await monitor.capture();
    
    const summary = monitor.getChangeSummary();
    expect(typeof summary).toBe('string');
  }, 20000);
});

describe('EconomicStore', () => {
  let store: EconomicStore;
  const testDir = TEST_DATA_DIR + '_store';

  beforeEach(() => {
    store = new EconomicStore({ dataDir: testDir });
  });

  afterEach(() => {
    if (existsSync(testDir)) {
      try {
        rmSync(testDir, { recursive: true });
      } catch {}
    }
  });

  it('should track snapshot trends', () => {
    const trends = store.getSnapshotTrends();
    expect(trends.totalSnapshots).toBe(0);
    expect(trends.timeSpan.first).toBeNull();
  });
});
