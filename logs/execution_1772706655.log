import { describe, it, expect } from 'vitest';
import {
  isValidStatusCode,
  isInformational,
  isSuccess,
  isRedirect,
  isClientError,
  isServerError,
  isError,
  isOk,
  isSafe,
  getDefaultStatusCode,
  assertValidStatusCode,
  getStatusDescription,
