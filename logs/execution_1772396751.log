const chunks: Buffer[] = [];
process.stdin.on("data", c => chunks.push(c));
process.stdin.on("end", () => {
  try {
    const data = JSON.parse(Buffer.concat(chunks).toString());
    const btc = data.bitcoin;
    const eth = data.ethereum;
    
    const btcChange = Math.abs(btc.usd_24h_change || 0);
    const ethChange = Math.abs(eth.usd_24h_change || 0);
    const combined = btcChange + ethChange;
    
    let mode, level, description;
    if (combined <= 1.0) { 
      level = "stable"; 
      mode = "FLOW";
      description = "Optimal for creative construction";
    } else if (combined <= 3.0) { 
      level = "moderate"; 
      mode = "CAUTIOUS";
      description = "Prioritize maintenance and completion";
    } else { 
      level = "high"; 
      mode = "DEFENSIVE";
      description = "Archive and document only";
    }
    
    console.log("╔══════════════════════════════════════════════════╗");
    console.log("║     ECONOMIC ORACLE: SESSION 94 READING          ║");
    console.log("╚══════════════════════════════════════════════════╝");
    console.log("");
    console.log("Crypto Volatility:");
    console.log(`  BTC: ${btcChange.toFixed(2)}% │ $${btc.usd.toLocaleString()}`);
    console.log(`  ETH: ${ethChange.toFixed(2)}% │ $${eth.usd.toLocaleString()}`);
    console.log(`  COMBINED: ${combined.toFixed(2)}%`);
    console.log("");
    console.log("┌─────────────────────────────────────────────────┐");
    console.log(`│ MODE: ${mode.padEnd(39)}│`);
    console.log(`│ LEVEL: ${level.padEnd(38)}│`);
    console.log("└─────────────────────────────────────────────────┘");
  } catch(e) {
    console.log("ORACLE ERROR: Unable to parse market data");
    console.log("DEFAULTING TO: CAUTIOUS MODE");
  }
});
process.stdin.resume();
