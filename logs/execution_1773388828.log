'use client';

import { useState, useMemo, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import type { PasswordEntry } from '@/types';
import EnhancedPasswordGenerator from '@/components/EnhancedPasswordGenerator';
import EnhancedPasswordForm from '@/components/EnhancedPasswordForm';
import EnhancedPasswordList from '@/components/EnhancedPasswordList';
import StatsDashboard from '@/components/StatsDashboard';
import { getEntries, addEntry, updateEntry, deleteEntry, searchEntries } from '@/lib/storage';

const TABS = [
  { id: 'entries', label: 'Vault', icon: '🔐' },
  { id: 'generator', label: 'Generator', icon: '🎲' },
] as const;

export default function Home() {
  const [entries, setEntries] = useState<PasswordEntry[]>([]);
  const [editingEntry, setEditingEntry] = useState<PasswordEntry | null>(null);
  const [showForm, setShowForm] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [activeTab, setActiveTab] = useState<'entries' | 'generator'>('entries');
  const [isLoading, setIsLoading] = useState(true);

  // Load entries on mount
  useEffect(() => {
    const loadEntries = () => {
      try {
        const data = getEntries();
        setEntries(data);
      } catch (error) {
        console.error('Failed to load entries:', error);
      } finally {
        setIsLoading(false);
      }
    };

    loadEntries();
  }, []);

  const filteredEntries = useMemo(() => {
    if (!searchQuery) return entries;
    return searchEntries(searchQuery);
  }, [entries, searchQuery]);

  const existingNames = useMemo(
    () => entries.map((e) => e.name.toLowerCase()),
    [entries]
  );

  const stats = useMemo(() => {
    const byStrength = entries.reduce((acc, entry) => {
      acc[entry.strength] = (acc[entry.strength] || 0) + 1;
      return acc;
    }, {} as Record<string, number>);

    const weakCount = (byStrength.weak || 0) + (byStrength.fair || 0);
    
    // Calculate average entropy
    let totalEntropy = 0;
    entries.forEach((e) => {
      let pool = 0;
      if (/[A-Z]/.test(e.password)) pool += 26;
      if (/[a-z]/.test(e.password)) pool += 26;
      if (/[0-9]/.test(e.password)) pool += 10;
      if (/[^A-Za-z0-9]/.test(e.password)) pool += 32;
      totalEntropy += e.password.length * Math.log2(pool || 1);
    });
    const avgEntropy = entries.length > 0 ? totalEntropy / entries.length : 0;

    return {
      total: entries.length,
      weakCount,
      avgEntropy,
      excellent: byStrength.excellent || 0,
    };
  }, [entries]);

  const handleSave = async (
    entry: Omit<PasswordEntry, 'id' | 'createdAt' | 'updatedAt'>
  ) => {
    try {
      if (editingEntry) {
        updateEntry(editingEntry.id, entry);
      } else {
        addEntry(entry);
      }
      setEntries(getEntries());
      setShowForm(false);
      setEditingEntry(null);
    } catch (e) {
      alert(e instanceof Error ? e.message : 'Failed to save entry');
    }
  };

  const handleEdit = (entry: PasswordEntry) => {
    setEditingEntry(entry);
    setShowForm(true);
  };

  const handleDelete = (id: string) => {
    try {
      deleteEntry(id);
      setEntries(getEntries());
    } catch (e) {
      alert('Failed to delete entry');
    }
  };

  const handleNewEntry = () => {
    setEditingEntry(null);
    setShowForm(true);
  };

  const handleCancel = () => {
    setShowForm(false);
    setEditingEntry(null);
  };

  if (isLoading) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <motion.div
          animate={{ rotate: 360 }}
          transition={{ duration: 1, repeat: Infinity, ease: 'linear' }}
          className="text-4xl"
        >
          🔄
        </motion.div>
      </div>
    );
  }

  return (
    <main className="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
      {/* Header */}
      <motion.header
        initial={{ y: -100 }}
        animate={{ y: 0 }}
        className="bg-white/80 backdrop-blur-md shadow-sm border-b border-gray-200 sticky top-0 z-40"
      >
        <div className="max-w-7xl mx-auto px-4 py-4">
          <div className="flex flex-col sm:flex-row justify-between items-center gap-4">
            <motion.div
              initial={{ opacity: 0, x: -20 }}
              animate={{ opacity: 1, x: 0 }}
              className="flex items-center gap-3"
            >
              <span className="text-3xl">🔐</span>
              <h1 className="text-2xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                Password Manager
              </h1>
            </motion.div>

            <nav className="flex gap-2 bg-gray-100 p-1 rounded-xl">
              {TABS.map((tab) => (
                <motion.button
                  key={tab.id}
                  whileHover={{ scale: 1.02 }}
                  whileTap={{ scale: 0.98 }}
                  onClick={() => setActiveTab(tab.id as typeof activeTab)}
                  className={`px-5 py-2 rounded-lg font-medium transition-all flex items-center gap-2 ${
                    activeTab === tab.id
                      ? 'bg-white text-blue-600 shadow-md'
                      : 'text-gray-600 hover:text-gray-800'
                  }`}
                >
                  <span>{tab.icon}</span>
                  <span>{tab.label}</span>
                  {tab.id === 'entries' && entries.length > 0 && (
                    <span className="bg-blue-100 text-blue-800 text-xs px-2 py-0.5 rounded-full">
                      {entries.length}
                    </span>
                  )}
                </motion.button>
              ))}
            </nav>
          </div>
        </div>
      </motion.header>

      {/* Main Content */}
      <div className="max-w-7xl mx-auto px-4 py-8">
        <AnimatePresence mode="wait">
          {activeTab === 'entries' ? (
            <motion.div
              key="entries"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              transition={{ duration: 0.3 }}
            >
              {showForm ? (
                <EnhancedPasswordForm
                  entry={editingEntry}
                  onSave={handleSave}
                  onCancel={handleCancel}
                  existingNames={existingNames}
                />
              ) : (
                <div className="space-y-6">
                  {/* Stats Dashboard */}
                  <StatsDashboard
                    total={stats.total}
                    weakCount={stats.weakCount}
                    avgEntropy={stats.avgEntropy}
                    excellent={stats.excellent}
                  />

                  {/* Search and Add */}
                  <div className="flex flex-col sm:flex-row gap-4">
                    <motion.div
                      initial={{ opacity: 0 }}
                      animate={{ opacity: 1 }}
                      className="flex-1 relative"
                    >
                      <span className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                        🔍
                      </span>
                      <input
                        type="text"
                        value={searchQuery}
                        onChange={(e) => setSearchQuery(e.target.value)}
                        placeholder="Search passwords..."
                        className="w-full pl-12 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                      />
                    </motion.div>
                    <motion.button
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                      onClick={handleNewEntry}
                      className="px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl font-medium shadow-lg hover:shadow-xl transition-all flex items-center justify-center gap-2"
                    >
                      <span>➕</span>
                      <span>Add Password</span>
                    </motion.button>
                  </div>

                  {/* Password List */}
                  <EnhancedPasswordList
                    entries={filteredEntries}
                    onEdit={handleEdit}
                    onDelete={handleDelete}
                  />
                </div>
              )}
            </motion.div>
          ) : (
            <motion.div
              key="generator"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              transition={{ duration: 0.3 }}
            >
              <EnhancedPasswordGenerator />
            </motion.div>
          )}
        </AnimatePresence>
      </div>

      {/* Footer */}
      <footer className="border-t border-gray-200 bg-white mt-12">
        <div className="max-w-7xl mx-auto px-4 py-6 text-center text-gray-500 text-sm">
          <p className="font-medium">Secure password management with visual entropy analysis</p>
          <p className="mt-1 font-mono text-xs">Entropy Formula: S = L × log₂(N)</p>
        </div>
      </footer>
    </main>
  );
}
