'use client';

import { useState } from 'react';
import type { PasswordEntry, PasswordStrength } from '@/types';
import { analyzePassword } from '@/lib/formulas';
import { MathJax } from 'better-react-mathjax';

interface PasswordListProps {
  entries: PasswordEntry[];
  onEdit: (entry: PasswordEntry) => void;
  onDelete: (id: string) => void;
  onViewFormulas: (password: string, entryName: string) => void;
}

const strengthColors: Record<PasswordStrength, string> = {
  weak: 'bg-red-500',
  fair: 'bg-orange-500',
  good: 'bg-yellow-500',
  strong: 'bg-green-500',
  excellent: 'bg-emerald-600',
};

export default function PasswordList({ entries, onEdit, onDelete, onViewFormulas }: PasswordListProps) {
  const [expandedId, setExpandedId] = useState<string | null>(null);
  const [showPasswords, setShowPasswords] = useState<Set<string>>(new Set());

  const togglePassword = (id: string) => {
    const newSet = new Set(showPasswords);
    if (newSet.has(id)) {
      newSet.delete(id);
    } else {
      newSet.add(id);
    }
    setShowPasswords(newSet);
  };

  const copyToClipboard = (text: string) => {
    navigator.clipboard.writeText(text);
  };

  if (entries.length === 0) {
    return (
      <div className="text-center py-12 text-gray-500">
        <p className="text-lg">No password entries yet.</p>
        <p>Add your first password using the form above!</p>
      </div>
    );
  }

  return (
    <div className="space-y-4">
      {entries.map(entry => (
        <div
          key={entry.id}
          className="bg-white rounded-lg shadow hover:shadow-md transition overflow-hidden"
        >
          {/* Header - Always visible */}
          <div
            className="p-4 cursor-pointer"
            onClick={() => setExpandedId(expandedId === entry.id ? null : entry.id)}
          >
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-3">
                <div className={`w-3 h-3 rounded-full ${strengthColors[entry.strength]}`} />
                <div>
                  <h3 className="font-semibold text-lg">{entry.name}</h3>
                  <p className="text-gray-500 text-sm">{entry.username}</p>
                </div>
              </div>
              <div className="flex items-center gap-2">
                <span className={`px-2 py-1 rounded text-xs text-white ${strengthColors[entry.strength]}`}>
                  {entry.strength}
                </span>
                <span className="text-gray-400">{expandedId === entry.id ? '▼' : '▶'}</span>
              </div>
            </div>
          </div>

          {/* Expanded Details */}
          {expandedId === entry.id && (
            <div className="border-t px-4 py-4 bg-gray-50">
              {/* Password Field */}
              <div className="mb-4">
                <label className="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <div className="flex gap-2">
                  <input
                    type={showPasswords.has(entry.id) ? 'text' : 'password'}
                    value={entry.password}
                    readOnly
                    className="flex-1 p-2 border rounded bg-white font-mono"
                  />
                  <button
                    onClick={() => togglePassword(entry.id)}
                    className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300"
                  >
                    {showPasswords.has(entry.id) ? '🙈' : '👁️'}
                  </button>
                  <button
                    onClick={() => copyToClipboard(entry.password)}
                    className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300"
                    title="Copy password"
                  >
                    📋
                  </button>
                </div>
              </div>

              {/* Username */}
              <div className="mb-4">
                <label className="block text-sm font-medium text-gray-700 mb-1">Username</label>
                <div className="flex gap-2">
                  <input
                    type="text"
                    value={entry.username}
                    readOnly
                    className="flex-1 p-2 border rounded bg-white"
                  />
                  <button
                    onClick={() => copyToClipboard(entry.username)}
                    className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300"
                    title="Copy username"
                  >
                    📋
                  </button>
                </div>
              </div>

              {/* URL */}
              {entry.url && (
                <div className="mb-4">
                  <label className="block text-sm font-medium text-gray-700 mb-1">URL</label>
                  <a
