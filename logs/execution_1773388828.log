'use client';

import { motion } from 'framer-motion';

interface EntropyVisualProps {
  password: string;
  poolSize: number;
  entropy: number;
}

export default function EntropyVisual({ password, poolSize, entropy }: EntropyVisualProps) {
  const hasUpper = /[A-Z]/.test(password);
  const hasLower = /[a-z]/.test(password);
  const hasNumber = /[0-9]/.test(password);
  const hasSymbol = /[^A-Za-z0-9]/.test(password);
  
  const charTypes = [
    { name: 'Uppercase', active: hasUpper, chars: 'A-Z', size: 26 },
    { name: 'Lowercase', active: hasLower, chars: 'a-z', size: 26 },
    { name: 'Numbers', active: hasNumber, chars: '0-9', size: 10 },
    { name: 'Symbols', active: hasSymbol, chars: '!@#', size: 32 },
  ];

  return (
    <div className="bg-gradient-to-br from-slate-50 to-slate-100 rounded-xl p-5 space-y-4">
      <h3 className="font-semibold text-gray-800 flex items-center gap-2">
        <span>🔐</span> Character Pool Analysis
      </h3>
      
      {/* Character type indicators */}
      <div className="grid grid-cols-2 gap-3">
        {charTypes.map((type) => (
          <motion.div
            key={type.name}
            initial={{ scale: 0.9, opacity: 0 }}
            animate={{ scale: 1, opacity: 1 }}
            className={`p-3 rounded-lg border-2 transition-all ${
              type.active 
                ? 'bg-green-50 border-green-400' 
                : 'bg-gray-50 border-gray-200 opacity-50'
            }`}
          >
            <div className="flex items-center justify-between">
              <span className="font-medium text-gray-800">{type.name}</span>
              <span className={`text-2xl ${type.active ? 'opacity-100' : 'opacity-30'}`}>
                {type.active ? '✅' : '❌'}
              </span>
            </div>
            <div className="text-sm text-gray-500 mt-1">{type.chars}</div>
            <div className={`text-xs font-mono mt-1 ${type.active ? 'text-green-700' : 'text-gray-400'}`}>
              +{type.size} characters
            </div>
          </motion.div>
        ))}
      </div>

      {/* Pool size indicator */}
      <div className="bg-white rounded-lg p-3 border border-slate-200">
        <div className="flex items-center justify-between">
          <span className="text-sm text-gray-600">Total Pool Size (N):</span>
          <motion.span 
            key={poolSize}
            initial={{ scale: 1.5, color: '#10b981' }}
            animate={{ scale: 1, color: '#111827' }}
            className="text-2xl font-bold font-mono"
          >
            {poolSize}
          </motion.span>
        </div>
        <div className="text-xs text-gray-500 mt-1 text-right">
          Possible combinations: {Math.pow(poolSize, password.length).toExponential(2)}
        </div>
      </div>

      {/* Formula display */}
      <div className="bg-white rounded-lg p-3 border border-slate-200 font-mono text-sm">
        <div className="text-gray-600 mb-1">Entropy Formula:</div>
        <div className="text-center py-2">
          <span className="text-lg">
            S = L × log₂(N) = {password.length} × log₂({poolSize}) ≈ {entropy.toFixed(2)} bits
          </span>
        </div>
      </div>
    </div>
  );
}
