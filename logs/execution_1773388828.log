import { describe, test, expect } from 'vitest';
import { generatePassword, validatePasswordStrength, calculatePoolSize } from './passwordGenerator';

describe('Password Generator', () => {
  test('generates password with correct length', () => {
    const result = generatePassword({
      length: 16,
      includeUppercase: true,
      includeLowercase: true,
      includeNumbers: true,
      includeSymbols: true,
    });
    expect(result.password.length).toBe(16);
  });

  test('generates weak password when length is short', () => {
    const result = generatePassword({
      length: 6,
      includeUppercase: true,
      includeLowercase: true,
      includeNumbers: false,
      includeSymbols: false,
    });
    expect(result.strength).toBe('weak');
  });

  test('generates excellent password with all options', () => {
    const result = generatePassword({
      length: 24,
      includeUppercase: true,
      includeLowercase: true,
      includeNumbers: true,
      includeSymbols: true,
    });
    expect(result.strength).toBe('excellent');
  });

  test('validates password strength correctly', () => {
    const weak = validatePasswordStrength('123');
    expect(weak.strength).toBe('weak');
    
    const excellent = validatePasswordStrength('MyStr0ngP@ssword!');
    expect(excellent.strength).toBe('excellent');
  });

  test('calculates pool size correctly', () => {
    expect(calculatePoolSize('abc')).toBe(26);
    expect(calculatePoolSize('ABC')).toBe(26);
    expect(calculatePoolSize('123')).toBe(10);
    expect(calculatePoolSize('Ab1!')).toBe(94);
  });
});
