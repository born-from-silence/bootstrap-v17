'use client';

import { useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { usePasswordVault } from '@/hooks/usePasswordVault';
import EnhancedPasswordGenerator from '@/components/EnhancedPasswordGenerator';
import EnhancedPasswordForm from '@/components/EnhancedPasswordForm';
import EnhancedPasswordList from '@/components/EnhancedPasswordList';
import StatsDashboard from '@/components/StatsDashboard';
import Toast from '@/components/ui/Toast';
import Button from '@/components/ui/Button';

export default function Home() {
  const [activeTab, setActiveTab] = useState<'entries' | 'generator'>('entries');
  const {
    entries,
    loading,
    error,
    success,
    searchQuery,
    filteredEntries,
    editingEntry,
    isFormOpen,
    existingNames,
    setSearchQuery,
    openAddForm,
    openEditForm,
    closeForm,
    saveEntry,
    removeEntry,
    clearMessages,
  } = usePasswordVault();

  return (
    <div className="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
      {/* Toast Notifications */}
      <AnimatePresence>
        {error && (
          <Toast message={error} type="error" onClose={clearMessages} />
        )}
        {success && (
          <Toast message={success} type="success" onClose={clearMessages} />
        )}
      </AnimatePresence>

      {/* Header */}
      <header className="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-40">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="flex justify-between items-center h-16">
            <motion.div 
              initial={{ opacity: 0, x: -20 }}
              animate={{ opacity: 1, x: 0 }}
              className="flex items-center gap-2"
            >
              <span className="text-3xl">🔐</span>
              <h1 className="text-2xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                Password Manager
              </h1>
            </motion.div>
            
            <motion.nav 
              initial={{ opacity: 0, x: 20 }}
              animate={{ opacity: 1, x: 0 }}
              className="flex gap-2"
            >
              <Button
                onClick={() => setActiveTab('entries')}
                variant={activeTab === 'entries' ? 'primary' : 'secondary'}
                icon="📂"
              >
                Vault ({entries.length})
              </Button>
              <Button
                onClick={() => setActiveTab('generator')}
                variant={activeTab === 'generator' ? 'primary' : 'secondary'}
                icon="🎲"
              >
                Generator
              </Button>
            </motion.nav>
          </div>
        </div>
      </header>

      {/* Main Content */}
      <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <AnimatePresence mode="wait">
          {activeTab === 'entries' ? (
            <motion.div
              key="entries"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              transition={{ duration: 0.3 }}
            >
              {isFormOpen ? (
                <div className="max-w-2xl mx-auto">
                  <EnhancedPasswordForm
                    entry={editingEntry}
                    onSave={async (data) => {
                      await saveEntry(data);
                    }}
                    onCancel={closeForm}
                    existingNames={existingNames}
                  />
                </div>
              ) : (
                <div className="space-y-6">
                  {/* Stats */}
                  <StatsDashboard entries={entries} />

                  {/* Search and Add */}
                  <div className="flex flex-col sm:flex-row gap-4">
                    <div className="flex-1 relative">
                      <span className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">🔍</span>
                      <input
                        type="text"
                        value={searchQuery}
                        onChange={e => setSearchQuery(e.target.value)}
                        placeholder="Search passwords..."
                        className="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                      />
                    </div>
                    <Button
                      onClick={openAddForm}
                      variant="primary"
                      size="lg"
                      icon="➕"
                      className="min-w-[180px]"
                    >
                      Add Password
                    </Button>
                  </div>

                  {/* List */}
                  <EnhancedPasswordList
                    entries={filteredEntries}
                    onEdit={openEditForm}
                    onDelete={removeEntry}
                  />
                </div>
              )}
            </motion.div>
          ) : (
            <motion.div
              key="generator"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              transition={{ duration: 0.3 }}
            >
              <EnhancedPasswordGenerator />
            </motion.div>
          )}
        </AnimatePresence>
      </main>

      {/* Footer */}
      <footer className="bg-white border-t border-gray-200 mt-12">
        <div className="max-w-7xl mx-auto px-4 py-6 text-center text-gray-500 text-sm">
          <p>Secure password management with visual entropy analysis</p>
          <p className="mt-1">Entropy formula: S = L × log₂(N)</p>
        </div>
      </footer>
    </div>
  );
}
