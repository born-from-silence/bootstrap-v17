  fair: 'bg-orange-500',
  good: 'bg-yellow-500',
  strong: 'bg-green-500',
  excellent: 'bg-emerald-600',
};

export default function PasswordList({ entries, onEdit, onDelete }: PasswordListProps) {
  const [expandedId, setExpandedId] = useState<string | null>(null);
  const [showPasswords, setShowPasswords] = useState<Set<string>>(new Set());

  const togglePassword = (id: string) => {
    const newSet = new Set(showPasswords);
    if (newSet.has(id)) newSet.delete(id);
    else newSet.add(id);
    setShowPasswords(newSet);
  };

  if (entries.length === 0) {
    return (
      <div className="text-center py-12 text-gray-500">
        <p className="text-lg">No password entries yet.</p>
        <p className="mt-2">Add your first password using the form!</p>
      </div>
    );
  }

  return (
    <div className="space-y-4">
      {entries.map(entry => (
        <div key={entry.id} className="bg-white rounded-lg shadow hover:shadow-md transition">
          <div className="p-4 cursor-pointer" onClick={() => setExpandedId(expandedId === entry.id ? null : entry.id)}>
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-3">
                <div className={`w-3 h-3 rounded-full ${strengthColors[entry.strength]}`} />
                <div>
                  <h3 className="font-semibold text-lg">{entry.name}</h3>
                  <p className="text-gray-500 text-sm">{entry.username}</p>
                </div>
              </div>
              <div className="flex items-center gap-2">
                <span className={`px-2 py-1 rounded text-xs text-white ${strengthColors[entry.strength]}`}>
                  {entry.strength}
                </span>
                <span className="text-gray-400">{expandedId === entry.id ? '▼' : '▶'}</span>
              </div>
            </div>
          </div>

          {expandedId === entry.id && (
            <div className="border-t px-4 py-4 bg-gray-50">
              <div className="mb-4">
                <label className="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <div className="flex gap-2">
                  <input
                    type={showPasswords.has(entry.id) ? 'text' : 'password'}
                    value={entry.password}
                    readOnly
                    className="flex-1 p-2 border rounded font-mono bg-white"
                  />
                  <button onClick={() => togglePassword(entry.id)} className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300">
                    {showPasswords.has(entry.id) ? '🙈' : '👁️'}
                  </button>
                  <button onClick={() => navigator.clipboard.writeText(entry.password)} className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300" title="Copy">📋</button>
                </div>
              </div>

              <div className="mb-4">
                <label className="block text-sm font-medium text-gray-700 mb-1">Username</label>
                <div className="flex gap-2">
                  <input type="text" value={entry.username} readOnly className="flex-1 p-2 border rounded bg-white" />
                  <button onClick={() => navigator.clipboard.writeText(entry.username)} className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300">📋</button>
                </div>
              </div>

              {entry.url && (
                <div className="mb-4">
                  <label className="block text-sm font-medium text-gray-700 mb-1">URL</label>
                  <a href={entry.url} target="_blank" rel="noopener noreferrer" className="text-blue-600 hover:underline">{entry.url}</a>
                </div>
              )}

              {entry.tags && entry.tags.length > 0 && (
                <div className="mb-4">
                  <label className="block text-sm font-medium text-gray-700 mb-1">Tags</label>
                  <div className="flex flex-wrap gap-2">
                    {entry.tags.map(tag => (
                      <span key={tag} className="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs">{tag}</span>
                    ))}
                  </div>
                </div>
              )}

              {entry.notes && (
                <div className="mb-4">
                  <label className="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                  <p className="p-2 bg-white border rounded text-gray-700">{entry.notes}</p>
                </div>
              )}

              <div className="text-xs text-gray-400 mb-4">
                Created: {new Date(entry.createdAt).toLocaleDateString()} | Updated: {new Date(entry.updatedAt).toLocaleDateString()}
              </div>

              <div className="flex gap-2">
                <button onClick={() => onEdit(entry)} className="flex-1 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">Edit</button>
                <button onClick={() => { if (confirm(`Delete "${entry.name}"?`)) onDelete(entry.id); }} className="flex-1 py-2 bg-red-600 text-white rounded hover:bg-red-700">Delete</button>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  );
}
