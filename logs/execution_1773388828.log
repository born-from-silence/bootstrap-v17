            <PasswordForm entry={editingEntry} onSave={handleSave} onCancel={() => {setShowForm(false); setEditingEntry(null);}} existingNames={existingNames} />
          ) : (
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
              <div className="space-y-4">
                <button onClick={() => setShowForm(true)} className="w-full bg-blue-600 text-white py-3 rounded hover:bg-blue-700">+ Add Password</button>
                <input type="text" value={searchQuery} onChange={e => setSearchQuery(e.target.value)} placeholder="Search..." className="w-full p-2 border rounded" />
              </div>
              <div className="lg:col-span-2">
                <PasswordList entries={filteredEntries} onEdit={e => { setEditingEntry(e); setShowForm(true); }} onDelete={handleDelete} />
              </div>
            </div>
          )
        ) : (
          <div className="max-w-xl mx-auto"><PasswordGenerator /></div>
        )}
      </div>
    </main>
  );
}
