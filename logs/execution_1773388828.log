  const [showFormulas, setShowFormulas] = useState(false);

  const handleGenerate = () => {
    try {
      const result = generatePassword({
        length: len, includeUppercase: upper, includeLowercase: lower,
        includeNumbers: number, includeSymbols: symbol,
      });
      setPassword(result.password);
    } catch (e) {
      alert(e instanceof Error ? e.message : 'Error');
    }
  };

  const analysis = password ? analyzePassword(password) : null;
  const strengthResult = password ? validatePasswordStrength(password) : null;

  const colors: Record<string, string> = {
    weak: 'bg-red-500', fair: 'bg-orange-500', good: 'bg-yellow-500',
    strong: 'bg-green-500', excellent: 'bg-emerald-600',
  };

  return (
    <div className="bg-white p-6 rounded-lg shadow-md">
      <h2 className="text-2xl font-bold mb-6">Password Generator</h2>
      
      <div className="mb-4">
        <label className="block text-sm font-medium mb-2">Length: <span className="font-bold">{len}</span></label>
        <input type="range" min="4" max="128" value={len} onChange={(e) => setLen(parseInt(e.target.value))} className="w-full" />
      </div>

      <div className="grid grid-cols-2 gap-4 mb-6">
        <label className="flex items-center space-x-2"><input type="checkbox" checked={upper} onChange={(e) => setUpper(e.target.checked)} /><span>Uppercase (A-Z)</span></label>
        <label className="flex items-center space-x-2"><input type="checkbox" checked={lower} onChange={(e) => setLower(e.target.checked)} /><span>Lowercase (a-z)</span></label>
        <label className="flex items-center space-x-2"><input type="checkbox" checked={number} onChange={(e) => setNumber(e.target.checked)} /><span>Numbers (0-9)</span></label>
        <label className="flex items-center space-x-2"><input type="checkbox" checked={symbol} onChange={(e) => setSymbol(e.target.checked)} /><span>Symbols (!@#$)</span></label>
      </div>

      <button onClick={handleGenerate} className="w-full bg-blue-600 text-white py-3 rounded-md hover:bg-blue-700 transition font-medium">
        Generate Password
      </button>

      {password && strengthResult && analysis && (
        <div className="mt-6">
          <div className={`inline-block px-3 py-1 rounded text-white text-sm mb-2 ${colors[strengthResult.strength]}`}>
            {strengthResult.strength.charAt(0).toUpperCase() + strengthResult.strength.slice(1)}
          </div>
          <div className="flex gap-2 mb-4">
            <input type="text" value={password} readOnly className="flex-1 p-3 border rounded-md font-mono bg-gray-50" />
            <button onClick={() => navigator.clipboard.writeText(password)} className="px-4 py-2 bg-gray-200 rounded-md hover:bg-gray-300">📋</button>
          </div>

          <button onClick={() => setShowFormulas(!showFormulas)} className="text-blue-600 hover:underline text-sm">
            {showFormulas ? 'Hide' : 'Show'} MathJax Formulas
          </button>

          {showFormulas && (
            <div className="mt-4 p-4 bg-slate-50 rounded-lg overflow-x-auto font-mono text-sm">
              <div className="mb-3"><strong>Entropy:</strong> {analysis.entropyFormula}</div>
              <div className="mb-3"><strong>Brute Force:</strong> {analysis.bruteForceFormula}</div>
              <div><strong>Time to Crack:</strong> {analysis.bruteForceTime}</div>
              <div className="mt-3 text-gray-600"><strong>Classification:</strong> {analysis.classification}</div>
              <div className="mt-1 text-gray-600"><strong>Security:</strong> {analysis.securityAssessment}</div>
            </div>
          )}
        </div>
      )}
    </div>
  );
}
