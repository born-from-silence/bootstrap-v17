'use client';

import { useState, useMemo, useEffect, useCallback } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import type { PasswordEntry, PasswordStrength } from '@/types';
import EnhancedPasswordForm from '@/components/EnhancedPasswordForm';
import EnhancedPasswordGenerator from '@/components/EnhancedPasswordGenerator';
import { getEntries, addEntry, updateEntry, deleteEntry, searchEntries } from '@/lib/storage';
import Card from '@/components/ui/Card';
import Button from '@/components/ui/Button';

// Password list with expand/collapse
function PasswordItem({ entry, onEdit, onDelete }: { entry: PasswordEntry; onEdit: (e: PasswordEntry) => void; onDelete: (id: string) => void }) {
  const [isExpanded, setIsExpanded] = useState(false);
  const [showPassword, setShowPassword] = useState(false);

  const strengthColors: Record<PasswordStrength, string> = {
    weak: 'bg-red-500', fair: 'bg-orange-500', good: 'bg-yellow-500',
    strong: 'bg-green-500', excellent: 'bg-emerald-600',
  };

  const copyToClipboard = (text: string) => {
    navigator.clipboard.writeText(text);
  };

  return (
    <Card className="overflow-hidden">
      <div
        className="p-4 cursor-pointer flex items-center justify-between"
        onClick={() => setIsExpanded(!isExpanded)}
      >
        <div className="flex items-center gap-3">
          <div className={`w-3 h-3 rounded-full ${strengthColors[entry.strength]}`} />
          <div>
            <h3 className="font-semibold text-lg">{entry.name}</h3>
            <p className="text-gray-500 text-sm">{entry.username}</p>
          </div>
        </div>
        <div className="flex items-center gap-2">
          <span className={`px-2 py-1 rounded text-xs text-white ${strengthColors[entry.strength]}`}>
            {entry.strength}
          </span>
          <span className="text-gray-400">{isExpanded ? '▼' : '▶'}</span>
        </div>
      </div>

      <AnimatePresence>
        {isExpanded && (
          <motion.div
            initial={{ height: 0, opacity: 0 }}
            animate={{ height: 'auto', opacity: 1 }}
            exit={{ height: 0, opacity: 0 }}
            className="border-t bg-gray-50 px-4 py-4"
          >
            <div className="space-y-3">
              <div>
                <label className="text-xs font-medium text-gray-500">Password</label>
                <div className="flex gap-2 mt-1">
                  <input
                    type={showPassword ? 'text' : 'password'}
                    value={entry.password}
                    readOnly
                    className="flex-1 p-2 border rounded font-mono bg-white"
                  />
                  <button onClick={() => setShowPassword(!showPassword)} className="px-3 bg-gray-200 rounded">{showPassword ? '🙈' : '👁️'}</button>
                  <button onClick={() => copyToClipboard(entry.password)} className="px-3 bg-gray-200 rounded">📋</button>
                </div>
              </div>
              {entry.url && <div><label className="text-xs text-gray-500">URL</label><a href={entry.url} target="_blank" className="text-blue-600 block">{entry.url}</a></div>}
              {entry.tags && entry.tags.length > 0 && (
                <div className="flex flex-wrap gap-1">
                  {entry.tags.map(t => <span key={t} className="px-2 py-0.5 bg-blue-100 text-blue-800 rounded text-xs">{t}</span>)}
                </div>
              )}
              <div className="flex gap-2 pt-2">
                <Button onClick={() => onEdit(entry)} variant="primary" className="flex-1" icon="✏️">Edit</Button>
                <Button onClick={() => { if (confirm(`Delete "${entry.name}"?`)) onDelete(entry.id); }} variant="danger" className="flex-1" icon="🗑️">Delete</Button>
              </div>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </Card>
  );
}

export default function Home() {
  const [entries, setEntries] = useState<PasswordEntry[]>([]);
  const [editingEntry, setEditingEntry] = useState<PasswordEntry | null>(null);
  const [showForm, setShowForm] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [tab, setTab] = useState<'vault' | 'generator'>('vault');
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => { setEntries(getEntries()); setIsLoading(false); }, []);

  const filtered = useMemo(() => searchQuery ? searchEntries(searchQuery) : entries, [entries, searchQuery]);
  const names = useMemo(() => entries.map(e => e.name.toLowerCase()), [entries]);

  const handleSave = useCallback(async (data: Omit<PasswordEntry, 'id' | 'createdAt' | 'updatedAt'>) => {
    try {
      if (editingEntry) updateEntry(editingEntry.id, data);
      else addEntry(data);
      setEntries(getEntries());
      setShowForm(false);
      setEditingEntry(null);
    } catch (e) {
      alert(e instanceof Error ? e.message : 'Failed to save');
    }
  }, [editingEntry]);

  const handleEdit = useCallback((entry: PasswordEntry) => { setEditingEntry(entry); setShowForm(true); }, []);
  
  const handleDelete = useCallback((id: string) => {
    deleteEntry(id); setEntries(getEntries());
  }, []);

  // Calculate stats
  const stats = useMemo(() => {
    const weak = entries.filter(e => e.strength === 'weak' ||
e.strength === 'fair').length;
    const excellent = entries.filter(e => e.strength === 'excellent').length;
    let entropy = 0; entries.forEach(e => { let n = 0; if (/[A-Z]/.test(e.password)) n += 26; if (/[a-z]/.test(e.password)) n += 26; if (/[0-9]/.test(e.password)) n += 10; if (/[^A-Za-z0-9]/.test(e.password)) n += 32; entropy += e.password.length * Math.log2(n || 1); });
    return { total: entries.length, weak, avg: entries.length ? entropy / entries.length : 0, excellent };
  }, [entries]);

  if (isLoading) return <div className="min-h-screen flex items-center justify-center text-2xl">🔄 Loading...</div>;

  return (
    <div className="min-h-screen bg-gray-50">
      <header className="bg-white shadow border-b sticky top-0 z-40">
        <div className="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
          <div className="flex items-center gap-2">
            <span className="text-3xl">🔐</span>
            <h1 className="text-2xl font-bold">Password Manager</h1>
          </div>
          <nav className="flex gap-2 bg-gray-100 p-1 rounded-lg">
            {[
              { id: 'vault', icon: '🔐', label: 'Vault', count: entries.length },
              { id: 'generator', icon: '🎲', label: 'Generator' },
            ].map((t) => (
              <button
                key={t.id}
                onClick={() => setTab(t.id as typeof tab)}
                className={`px-4 py-2 rounded-md font-medium transition-all flex items-center gap-2 ${tab === t.id ? 'bg-white text-blue-600 shadow' : 'text-gray-600'}`}
              >
                <span>{t.icon}</span>
                <span>{t.label}</span>
                {'count' in t && t.count > 0 && <span className="bg-blue-100 text-blue-800 text-xs px-1.5 py-0.5 rounded-full">{t.count}</span>}
              </button>
            ))}
          </nav>
        </div>
      </header>

      <main className="max-w-6xl mx-auto px-4 py-6">
        <AnimatePresence mode="wait">
          {tab === 'vault' ? (
            <motion.div key="vault" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              {showForm ? (
                <EnhancedPasswordForm entry={editingEntry} onSave={handleSave} onCancel={() => {setShowForm(false); setEditingEntry(null);}} existingNames={names} />
              ) : (
                <div className="space-y-4">
                  {/* Stats */}
                  <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                    {[
                      { label: 'Total', value: stats.total, color: 'blue' },
                      { label: 'Weak', value: stats.weak, color: stats.weak ? 'red' : 'gray' },
                      { label: 'Avg Entropy', value: `${stats.avg.toFixed(0)} bits`, color: 'purple' },
                      { label: 'Excellent', value: stats.excellent, color: 'green' },
                    ].map(s => (
                      <Card key={s.label} className="p-4 text-center">
                        <div className={`text-2xl font-bold text-${s.color}-600`}>{s.value}</div>
                        <div className="text-sm text-gray-500">{s.label}</div>
                      </Card>
                    ))}
                  </div>

                  {/* Search & Add */}
                  <div className="flex flex-col sm:flex-row gap-3">
                    <div className="flex-1 relative">
                      <span className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">🔍</span>
                      <input type="text" value={searchQuery} onChange={e => setSearchQuery(e.target.value)} placeholder="Search passwords..." className="w-full pl-10 pr-4 py-3 border rounded-lg" />
                    </div>
                    <Button onClick={() => { setEditingEntry(null); setShowForm(true); }} variant="primary" icon="➕" className="min-w-[140px]">Add</Button>
                  </div>

                  {/* List */}
                  <div className="space-y-3">
                    {filtered.length === 0 ? (
                      <Card className="p-8 text-center"><div className="text-4xl mb-2">🔐</div><p className="text-gray-500">No passwords yet. Add your first!</p></Card>
                    ) : (
                      filtered.map(entry => <PasswordItem key={entry.id} entry={entry} onEdit={handleEdit} onDelete={handleDelete} />)
                    )}
                  </div>
                </div>
              )}
            </motion.div>
          ) : (
            <motion.div key="generator" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              <EnhancedPasswordGenerator />
            </motion.div>
          )}
        </AnimatePresence>
      </main>

      <footer className="border-t mt-12 bg-white">
        <div className="max-w-6xl mx-auto px-4 py-4 text-center text-sm text-gray-500">
          Entropy Formula: S = L × log₂(N)
        </div>
      </footer>
    </div>
  );
}
