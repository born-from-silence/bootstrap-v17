'use client';

import { useMemo } from 'react';
import { PasswordStrength } from '@/types';
import type { PasswordEntry } from '@/types';

interface StatsViewProps {
  entries: PasswordEntry[];
}

export default function StatsView({ entries }: StatsViewProps) {
  const stats = useMemo(() => {
    const byStrength: Record<PasswordStrength, number> = {
      weak: 0,
      fair: 0,
      good: 0,
      strong: 0,
      excellent: 0,
    };

    const byTag: Record<string, number> = {};
    const now = Date.now();
    let totalAge = 0;

    entries.forEach(e => {
      byStrength[e.strength]++;
      e.tags?.forEach(tag => {
        byTag[tag] = (byTag[tag] || 0) + 1;
      });
      const age = (now - new Date(e.createdAt).getTime()) / (1000 * 60 * 60 * 24);
      totalAge += age;
    });

    return {
      total: entries.length,
      byStrength,
      byTag,
      averageAge: entries.length > 0 ? totalAge / entries.length : 0,
    };
  }, [entries]);

  const strengthOrder: PasswordStrength[] = ['weak', 'fair', 'good', 'strong', 'excellent'];
  const strengthColors: Record<PasswordStrength, string> = {
    weak: 'bg-red-500',
    fair: 'bg-orange-500',
    good: 'bg-yellow-500',
    strong: 'bg-green-500',
    excellent: 'bg-emerald-600',
  };

  if (entries.length === 0) {
    return null;
  }

  return (
    <div className="bg-white p-6 rounded-lg shadow-md mb-6">
      <h2 className="text-xl font-bold mb-4">Vault Statistics</h2>

      {/* Total and Average Age */}
      <div className="grid grid-cols-2 gap-4 mb-6">
        <div className="bg-blue-50 p-4 rounded-lg">
          <p className="text-sm text-gray-600">Total Entries</p>
          <p className="text-3xl font-bold text-blue-600">{stats.total}</p>
        </div>
        <div className="bg-purple-50 p-4 rounded-lg">
          <p className="text-sm text-gray-600">Average Password Age</p>
          <p className="text-3xl font-bold text-purple-600">
            {stats.averageAge.toFixed(0)} <span className="text-sm">days</span>
          </p>
        </div>
      </div>

      {/* Strength Distribution */}
      <h3 className="font-semibold mb-3">Strength Distribution</h3>
      <div className="space-y-2 mb-6">
        {strengthOrder.map(strength => {
          const count = stats.byStrength[strength];
          const percentage = stats.total > 0 ? (count / stats.total) * 100 : 0;
          return (
            <div key={strength} className="flex items-center gap-3">
              <span className="w-20 text-sm capitalize">{strength}</span>
              <div className="flex-1 h-6 bg-gray-100 rounded-full overflow-hidden">
                <div
                  className={`h-full ${strengthColors[strength]} transition-all duration-500`}
                  style={{ width: `${percentage}%` }}
                />
              </div>
              <span className="w-12 text-right text-sm font-medium">{count}</span>
            </div>
          );
        })}
      </div>

      {/* Tag Cloud */}
      {Object.keys(stats.byTag).length > 0 && (
        <>
          <h3 className="font-semibold mb-3">Tags</h3>
          <div className="flex flex-wrap gap-2">
            {Object.entries(stats.byTag)
              .sort((a, b) => b[1] - a[1])
              .map(([tag, count]) => (
                <span
                  key={tag}
                  className="px-3 py-1 bg-gray-100 rounded-full text-sm"
                >
                  {tag} ({count})
                </span>
              ))}
          </div>
        </>
      )}
    </div>
  );
}
