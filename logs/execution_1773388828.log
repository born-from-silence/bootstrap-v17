'use client';

import { motion } from 'framer-motion';

type Strength = 'weak' | 'fair' | 'good' | 'strong' | 'excellent';

interface StrengthMeterProps {
  strength: Strength;
  entropy: number;
  showDetails?: boolean;
}

const strengthConfig: Record<Strength, { color: string; label: string; width: string; emoji: string }> = {
  weak: { color: 'bg-red-500', label: 'Weak', width: '20%', emoji: '⚠️' },
  fair: { color: 'bg-orange-500', label: 'Fair', width: '40%', emoji: '😐' },
  good: { color: 'bg-yellow-500', label: 'Good', width: '60%', emoji: '🙂' },
  strong: { color: 'bg-green-500', label: 'Strong', width: '80%', emoji: '💪' },
  excellent: { color: 'bg-emerald-600', label: 'Excellent', width: '100%', emoji: '🛡️' },
};

const entropyRanges = [
  { min: 0, max: 40, label: '< 40 bits', time: 'Seconds to minutes' },
  { min: 40, max: 60, label: '40-60 bits', time: 'Hours to days' },
  { min: 60, max: 80, label: '60-80 bits', time: 'Months to years' },
  { min: 80, max: 100, label: '80-100 bits', time: 'Decades to centuries' },
  { min: 100, max: Infinity, label: '> 100 bits', time: 'Practically uncrackable' },
];

export default function StrengthMeter({ strength, entropy, showDetails = true }: StrengthMeterProps) {
  const config = strengthConfig[strength];
  const range = entropyRanges.find(r => entropy >= r.min && entropy < r.max) || entropyRanges[4];

  return (
    <div className="space-y-3">
      {/* Main Bar */}
      <div className="relative">
        <div className="flex justify-between items-center mb-2">
          <span className="text-sm font-medium text-gray-700 flex items-center gap-2">
            {config.emoji} Strength: {config.label}
          </span>
          <span className="text-sm font-semibold text-gray-900">{entropy.toFixed(1)} bits</span>
        </div>
        
        <div className="h-3 bg-gray-200 rounded-full overflow-hidden">
          <motion.div
            initial={{ width: 0 }}
            animate={{ width: config.width }}
            transition={{ duration: 0.5, ease: "easeOut" }}
            className={`h-full ${config.color} rounded-full`}
          />
        </div>
        
        {/* Tick marks */}
        <div className="flex justify-between mt-1 px-1">
          {[20, 40, 60, 80, 100].map((tick) => (
            <div key={tick} className="flex flex-col items-center">
              <div className={`w-0.5 h-2 rounded-full ${entropy >= tick ? config.color : 'bg-gray-300'}`} />
              <span className="text-[10px] text-gray-400 mt-0.5">{tick}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Details Panel */}
      {showDetails && (
        <motion.div
          initial={{ opacity: 0, height: 0 }}
          animate={{ opacity: 1, height: 'auto' }}
          className="bg-slate-50 rounded-lg p-3 text-sm space-y-2"
        >
          <div className="flex justify-between">
            <span className="text-gray-600">Entropy Range:</span>
            <span className="font-medium">{range.label}</span>
          </div>
          <div className="flex justify-between">
            <span className="text-gray-600">Estimated Crack Time:</span>
            <span className={`font-medium ${strength === 'weak' || strength === 'fair' ? 'text-red-600' : 'text-green-600'}`}>
              {range.time}
            </span>
          </div>
        </motion.div>
      )}
    </div>
  );
}
