                className="ml-2 text-blue-600 text-xs hover:underline"
              >
                {showFormulas ? 'Hide Formulas' : 'Show Formulas'}
              </button>
            </div>
          )}
          
          {getFieldErrors({ valid: true, errors }, 'password').map((err, i) => (
            <p key={i} className="text-red-500 text-sm mt-1">{err}</p>
          ))}
        </div>

        {/* MathJax Formulas */}
        {showFormulas && formData.password && (
