'use client';

import { useState, useEffect, useCallback } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import Card from './ui/Card';
import Button from './ui/Button';
import Input from './ui/Input';
import StrengthMeter from './visuals/StrengthMeter';
import EntropyVisual from './visuals/EntropyVisual';
import { generatePassword, validatePasswordStrength } from '@/lib/passwordGenerator';
import { analyzePassword } from '@/lib/formulas';
import { validateEntry, getFieldErrors } from '@/lib/validation';
import type { PasswordEntry, PasswordStrength, ValidationResult } from '@/types';

interface EnhancedPasswordFormProps {
  entry?: PasswordEntry | null;
  onSave: (data: Omit<PasswordEntry, 'id' | 'createdAt' | 'updatedAt'>) => void;
  onCancel: () => void;
  existingNames?: string[];
}

const DEFAULT_ENTRY = {
  name: '',
  username: '',
  password: '',
  url: '',
  notes: '',
  tags: [] as string[],
  strength: 'weak' as PasswordStrength,
};

export default function EnhancedPasswordForm({
  entry,
  onSave,
  onCancel,
  existingNames = [],
}: EnhancedPasswordFormProps) {
  const [formData, setFormData] = useState(DEFAULT_ENTRY);
  const [errors, setErrors] = useState<ValidationResult['errors']>({});
  const [showPassword, setShowPassword] = useState(false);
  const [showAnalysis, setShowAnalysis] = useState(false);
  const [tagInput, setTagInput] = useState('');

  // Initialize form when editing
  useEffect(() => {
    if (entry) {
      setFormData({
        name: entry.name,
        username: entry.username,
        password: entry.password,
        url: entry.url || '',
        notes: entry.notes || '',
        tags: entry.tags || [],
        strength: entry.strength,
      });
    } else {
      setFormData(DEFAULT_ENTRY);
    }
    setErrors({});
    setShowAnalysis(false);
  }, [entry]);

  const handleChange = useCallback((field: keyof typeof formData, value: any) => {
    setFormData((prev) => ({ ...prev, [field]: value }));
    
    // Clear field errors on change
    if (errors[field]) {
      setErrors((prev) => {
        const next = { ...prev };
        delete next[field];
        return next;
      });
    }

    // Update strength on password change
    if (field === 'password') {
      const { strength } = validatePasswordStrength(value);
      setFormData((prev) => ({ ...prev, strength }));
      if (value.length > 0) setShowAnalysis(true);
    }
  }, [errors]);

  const generateNewPassword = useCallback(() => {
    try {
      const { password, strength } = generatePassword({
        length: 20,
        includeUppercase: true,
        includeLowercase: true,
        includeNumbers: true,
        includeSymbols: true,
      });
      
      setFormData((prev) => ({ ...prev, password, strength }));
      setShowPassword(true);
      setShowAnalysis(true);
    } catch {
      // Silent fail - generator validates internally
    }
  }, []);

  const handleAddTag = useCallback(() => {
    const trimmed = tagInput.trim();
    if (trimmed && !formData.tags.includes(trimmed)) {
      handleChange('tags', [...formData.tags, trimmed]);
      setTagInput('');
    }
  }, [tagInput, formData.tags, handleChange]);

  const removeTag = useCallback((tagToRemove: string) => {
    handleChange('tags', formData.tags.filter((t) => t !== tagToRemove));
  }, [formData.tags, handleChange]);

  const handleSubmit = useCallback((e: React.FormEvent) => {
    e.preventDefault();

    // Check for duplicates
    const dupErrors: ValidationResult['errors'] = {};
    if (
      formData.name &&
      existingNames.includes(formData.name.toLowerCase()) &&
      (!entry || entry.name.toLowerCase() !== formData.name.toLowerCase())
    ) {
      dupErrors.name = [`"${formData.name}" already exists`];
    }

    const validation = validateEntry({
      name: formData.name,
      username: formData.username,
      password: formData.password,
      url: formData.url,
      notes: formData.notes,
    });

    if (!validation.valid || Object.keys(dupErrors).length > 0) {
      setErrors({ ...validation.errors, ...dupErrors });
      return;
    }

    onSave(formData);
  }, [formData, entry, existingNames, onSave]);

  const analysis = formData.password ? analyzePassword(formData.password) : null;
  const isSubmitting = false;

  return (
    <Card className="max-w-2xl mx-auto p-6" animate>
      <motion.h2
        initial={{ opacity: 0, x: -20 }}
        animate={{ opacity: 1, x: 0 }}
        className="text-2xl font-bold mb-6"
      >
        {entry ? '✏️ Edit Password' : '➕ Add New Password'}
      </motion.h2>

      <form onSubmit={handleSubmit} className="space-y-5">
        <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
          <Input
            label="Name"
            value={formData.name}
            onChange={(e) => handleChange('name', e.target.value)}
            error={getFieldErrors({ valid: true, errors }, 'name')[0]}
            placeholder="e.g., Gmail"
            required
          />
          <Input
            label="Username"
            value={formData.username}
            onChange={(e) => handleChange('username', e.target.value)}
            error={getFieldErrors({ valid: true, errors }, 'username')[0]}
            placeholder="user@example.com"
            required
          />
        </div>

        {/* Password Field with Generator */}
        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1">
            Password <span className="text-red-500">*</span>
          </label>
          <div className="flex gap-2">
            <div className="relative flex-1">
              <input
                type={showPassword ? 'text' : 'password'}
                value={formData.password}
                onChange={(e) => handleChange('password', e.target.value)}
                className={`w-full px-4 py-2 border rounded-lg pr-10 transition-all ${
                  getFieldErrors({ valid: true, errors }, 'password').length
                    ? 'border-red-500 focus:ring-red-200'
                    : 'border-gray-300 focus:ring-blue-200 focus:border-blue-500'
                }`}
              />
              <button
                type="button"
                onClick={() => setShowPassword(!showPassword)}
                className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-700"
              >
                {showPassword ? '🙈' : '👁️'}
              </button>
            </div>
            <Button
              type="button"
              variant="secondary"
              onClick={generateNewPassword}
              icon="🎲"
            >
              Generate
            </Button>
          </div>
          {getFieldErrors({ valid: true, errors }, 'password').map((err, i) => (
            <p key={i} className="text-red-500 text-sm mt-1">{err}</p>
          ))}
        </div>

        {/* Strength Meter & Analysis */}
        <AnimatePresence>
          {analysis && (
            <motion.div
              initial={{ opacity: 0, height: 0 }}
              animate={{ opacity: 1, height: 'auto' }}
              exit={{ opacity: 0, height: 0 }}
            >
              <StrengthMeter
                strength={formData.strength}
                entropy={analysis.entropy}
                showDetails={showAnalysis}
              />
              
              {showAnalysis && (
                <motion.div
                  initial={{ opacity: 0 }}
                  animate={{ opacity: 1 }}
                  className="mt-4"
                >
                  <EntropyVisual
                    password={formData.password}
                    poolSize={analysis.poolSize}
                    entropy={analysis.entropy}
                  />
                </motion.div>
              )}
            </motion.div>
          )}
        </AnimatePresence>

        <Input
          label="URL (optional)"
          type="url"
          value={formData.url}
          onChange={(e) => handleChange('url', e.target.value)}
          placeholder="https://example.com"
        />

        {/* Tags */}
        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1">Tags</label>
          <div className="flex gap-2">
            <input
              type="text"
              value={tagInput}
              onChange={(e) => setTagInput(e.target.value)}
              onKeyPress={(e) => e.key === 'Enter' && (e.preventDefault(), handleAddTag())}
              placeholder="Add tag..."
              className="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-200"
            />
            <Button type="button" variant="secondary" onClick={handleAddTag}>
              Add
            </Button>
          </div>
          <AnimatePresence>
            {formData.tags.length > 0 && (
              <motion.div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                className="flex flex-wrap gap-2 mt-2"
              >
                {formData.tags.map((tag) => (
                  <motion.span
                    key={tag}
                    initial={{ opacity: 0, scale: 0.8 }}
                    animate={{ opacity: 1, scale: 1 }}
                    exit={{ opacity: 0, scale: 0.8 }}
                    className="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm flex items-center gap-1"
                  >
                    {tag}
                    <button
                      type="button"
                      onClick={() => removeTag(tag)}
                      className="text-blue-600 hover:text-red-500 font-bold ml-1"
                    >
                      ×
                    </button>
                  </motion.span>
                ))}
              </motion.div>
            )}
          </AnimatePresence>
        </div>

        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1">Notes</label>
          <textarea
            value={formData.notes}
            onChange={(e) => handleChange('notes', e.target.value)}
            rows={3}
            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-200 resize-vertical"
            placeholder="Optional notes..."
          />
        </div>

        {/* Actions */}
        <div className="flex gap-3 pt-4">
          <Button
            type="submit"
            variant="primary"
            size="lg"
            className="flex-1"
            icon="💾"
            disabled={isSubmitting}
          >
            {entry ? 'Update' : 'Save'} Entry
          </Button>
          <Button
            type="button"
            variant="secondary"
            size="lg"
            className="flex-1"
            onClick={onCancel}
          >
            Cancel
          </Button>
        </div>
      </form>
    </Card>
  );
}
