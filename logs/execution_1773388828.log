'use client';

import { useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import type { PasswordEntry } from '@/types';
import Card from './ui/Card';
import Button from './ui/Button';
import { analyzePassword } from '@/lib/formulas';

interface Props {
  entries: PasswordEntry[];
  onEdit: (e: PasswordEntry) => void;
  onDelete: (id: string) => void;
}

const strengthColors = {
  weak: 'bg-red-500',
  fair: 'bg-orange-500',
  good: 'bg-yellow-500',
  strong: 'bg-green-500',
  excellent: 'bg-emerald-600',
};

const strengthEmoji = {
  weak: '⚠️',
  fair: '😐',
  good: '🙂',
  strong: '💪',
  excellent: '🛡️',
};

export default function EnhancedPasswordList({ entries, onEdit, onDelete }: Props) {
  const [expandedId, setExpandedId] = useState<string | null>(null);
  const [showPasswords, setShowPasswords] = useState<Set<string>>(new Set());
  const [copiedId, setCopiedId] = useState<string | null>(null);

  const togglePassword = (id: string) => {
    const newSet = new Set(showPasswords);
    if (newSet.has(id)) newSet.delete(id);
    else newSet.add(id);
    setShowPasswords(newSet);
  };

  const copyToClipboard = async (text: string, id: string) => {
    await navigator.clipboard.writeText(text);
    setCopiedId(id);
    setTimeout(() => setCopiedId(null), 2000);
  };

  if (entries.length === 0) {
    return (
      <Card className="p-12 text-center">
        <motion.div
          initial={{ scale: 0.8, opacity: 0 }}
          animate={{ scale: 1, opacity: 1 }}
          className="space-y-4"
        >
          <div className="text-6xl">🔐</div>
          <h3 className="text-xl font-semibold text-gray-700">No passwords yet</h3>
          <p className="text-gray-500">Add your first password to get started</p>
        </motion.div>
      </Card>
    );
  }

  return (
    <div className="space-y-4">
      <AnimatePresence>
        {entries.map((entry, index) => {
          const isExpanded = expandedId === entry.id;
          const analysis = analyzePassword(entry.password);
          
          return (
            <motion.div
              key={entry.id}
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              transition={{ delay: index * 0.05 }}
            >
              <Card className={isExpanded ? 'ring-2 ring-blue-500' : ''}>
                {/* Header */}
                <div 
                  className="p-4 cursor-pointer"
                  onClick={() => setExpandedId(isExpanded ? null : entry.id)}
                >
                  <div className="flex items-center justify-between">
                    <div className="flex items-center gap-3">
                      <div className={`w-3 h-3 rounded-full ${strengthColors[entry.strength]}`} />
                      <div>
                        <h3 className="font-semibold text-lg">{entry.name}</h3>
                        <p className="text-gray-500 text-sm">{entry.username}</p>
                      </div>
                    </div>
                    <div className="flex items-center gap-2">
                      <span className={`px-2 py-1 rounded-full text-xs text-white ${strengthColors[entry.strength]}`}>
                        {strengthEmoji[entry.strength]} {entry.strength}
                      </span>
                      <motion.span 
                        animate={{ rotate: isExpanded ? 180 : 0 }}
                        className="text-gray-400"
                      >
                        ▼
                      </motion.span>
                    </div>
                  </div>
                </div>

                {/* Expanded Content */}
                <AnimatePresence>
                  {isExpanded && (
                    <motion.div
                      initial={{ height: 0, opacity: 0 }}
                      animate={{ height: 'auto', opacity: 1 }}
                      exit={{ height: 0, opacity: 0 }}
                      className="border-t border-gray-100 bg-gray-50"
                    >
                      <div className="p-4 space-y-4">
                        {/* Password */}
                        <div>
                          <label className="text-xs font-medium text-gray-500 uppercase">Password</label>
                          <div className="flex gap-2 mt-1">
                            <div className="flex-1 bg-white px-3 py-2 rounded border font-mono">
                              {showPasswords.has(entry.id) ? entry.password : '•'.repeat(Math.min(20, entry.password.length))}
                            </div>
                            <Button
                              onClick={() => togglePassword(entry.id)}
                              variant="secondary"
                              size="sm"
                              icon={showPasswords.has(entry.id) ? '🙈' : '👁️'}
                            />
                            <Button
                              onClick={() => copyToClipboard(entry.password, entry.id)}
                              variant="secondary"
                              size="sm"
                              icon={copiedId === entry.id ? '✅' : '📋'}
                            />
                          </div>
                          {analysis && (
                            <p className="text-xs text-gray-500 mt-1">
                              Entropy: {analysis.entropy.toFixed(1)} bits | Crack time: {analysis.bruteForceTime}
                            </p>
                          )}
                        </div>

                        {/* Other fields */}
                        {entry.url && (
                          <div>
                            <label className="text-xs font-medium text-gray-500 uppercase">URL</label>
                            <a 
                              href={entry.url} 
                              target="_blank" 
                              rel="noopener noreferrer"
                              className="text-blue-600 hover:underline block mt-1"
                              onClick={e => e.stopPropagation()}
                            >
                              {entry.url}
                            </a>
                          </div>
                        )}

                        {entry.tags && entry.tags.length > 0 && (
                          <div>
                            <label className="text-xs font-medium text-gray-500 uppercase">Tags</label>
                            <div className="flex flex-wrap gap-2 mt-1">
                              {entry.tags.map(tag => (
                                <span key={tag} className="px-2 py-1 bg-blue-100 text-blue-800 rounded text-xs">
                                  #{tag}
                                </span>
                              ))}
                            </div>
                          </div>
                        )}

                        {entry.notes && (
                          <div>
                            <label className="text-xs font-medium text-gray-500 uppercase">Notes</label>
                            <p className="text-gray-700 mt-1">{entry.notes}</p>
                          </div>
                        )}

                        {/* Dates */}
                        <div className="text-xs text-gray-400">
                          Created: {new Date(entry.createdAt).toLocaleString()} | 
                          Updated: {new Date(entry.updatedAt).toLocaleString()}
                        </div>

                        {/* Actions */}
                        <div 
                          className="flex gap-2 pt-2"
                          onClick={e => e.stopPropagation()}
                        >
                          <Button
                            onClick={() => onEdit(entry)}
                            variant="primary"
                            icon="✏️"
                            className="flex-1"
                          >
                            Edit
                          </Button>
                          <Button
                            onClick={() => {
                              if (confirm(`Delete "${entry.name}"?`)) onDelete(entry.id);
                            }}
                            variant="danger"
                            icon="🗑️"
                            className="flex-1"
                          >
                            Delete
                          </Button>
                        </div>
                      </div>
                    </motion.div>
                  )}
                </AnimatePresence>
              </Card>
            </motion.div>
          );
        })}
      </AnimatePresence>
    </div>
  );
}
