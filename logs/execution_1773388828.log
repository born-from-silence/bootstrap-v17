'use client';

import { useEffect } from 'react';
import { MathJax } from 'better-react-mathjax';
import { generateCompleteAnalysis } from '@/lib/formulas';

interface FormulaModalProps {
  password: string;
  entryName: string;
  onClose: () => void;
}

export default function FormulaModal({ password, entryName, onClose }: FormulaModalProps) {
  // Close on Escape key
  useEffect(() => {
    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape') onClose();
    };
    window.addEventListener('keydown', handleEscape);
    return () => window.removeEventListener('keydown', handleEscape);
  }, [onClose]);

  return (
    <div
      className="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50"
      onClick={onClose}
    >
      <div
        className="bg-white rounded-lg max-w-4xl max-h-[90vh] overflow-y-auto p-6"
        onClick={e => e.stopPropagation()}
      >
        <div className="flex items-center justify-between mb-6">
          <h2 className="text-xl font-bold">Security Analysis: {entryName}</h2>
          <button
            onClick={onClose}
            className="px-3 py-1 bg-gray-200 rounded hover:bg-gray-300"
          >
            ✕
          </button>
        </div>

        <div className="bg-slate-50 p-6 rounded-lg overflow-x-auto">
          <MathJax>
            {`$$\\text{Password: } \\text{${password.replace(/\\/g, '\\\\').replace(/\$/g, '\\$')}}$`}
          </MathJax>
          <hr className="my-4 border-gray-300" />
          <MathJax>
            {generateCompleteAnalysis(password)}
          </MathJax>
        </div>

        <div className="mt-6 text-sm text-gray-500">
          <p>Formulas based on Shannon Entropy and brute force calculations.</p>
          <p>Assumes 1 billion attempts per second for brute force estimation.</p>
        </div>
      </div>
    </div>
  );
}
