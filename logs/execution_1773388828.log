'use client';

import { useState, useMemo, useEffect } from 'react';
import type { PasswordEntry } from '@/types';
import PasswordGenerator from '@/components/PasswordGenerator';
import PasswordForm from '@/components/PasswordForm';
import PasswordList from '@/components/PasswordList';
import { getEntries, addEntry, updateEntry, deleteEntry, searchEntries } from '@/lib/storage';
import { usePasswordStore } from '@/lib/store';

export default function Home() {
  const { entries, loadEntries } = usePasswordStore();
  const [editingEntry, setEditingEntry] = useState<PasswordEntry | null>(null);
  const [showForm, setShowForm] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [activeTab, setActiveTab] = useState<'entries' | 'generator'>('entries');

  useEffect(() => {
    loadEntries();
  }, [loadEntries]);

  const filteredEntries = useMemo(() => {
    if (!searchQuery) return entries;
    return searchEntries(searchQuery);
  }, [entries, searchQuery]);

  const existingNames = useMemo(() => 
    entries.map(e => e.name.toLowerCase()),
    [entries]
  );

  const handleSave = (entry: Omit<PasswordEntry, 'id' | 'createdAt' | 'updatedAt'>) => {
    try {
      if (editingEntry) {
        updateEntry(editingEntry.id, entry);
      } else {
        addEntry(entry);
      }
      loadEntries();
      setShowForm(false);
      setEditingEntry(null);
    } catch (e) {
      alert(e instanceof Error ? e.message : 'Failed to save');
    }
  };

  const handleEdit = (entry: PasswordEntry) => {
    setEditingEntry(entry);
    setShowForm(true);
  };

  const handleDelete = (id: string) => {
    deleteEntry(id);
    loadEntries();
  };

  const handleNewEntry = () => {
    setEditingEntry(null);
    setShowForm(true);
  };

  const handleCancel = () => {
    setShowForm(false);
    setEditingEntry(null);
  };

  return (
    <main className="min-h-screen bg-gray-100">
      <header className="bg-white shadow-sm border-b">
        <div className="max-w-6xl mx-auto px-4 py-4">
          <div className="flex items-center justify-between">
            <h1 className="text-2xl font-bold">🔐 Password Manager</h1>
            <nav className="flex gap-4">
              <button
                onClick={() => setActiveTab('entries')}
                className={`px-4 py-2 rounded transition ${activeTab === 'entries' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}`}
              >
                Entries ({entries.length})
              </button>
              <button
                onClick={() => setActiveTab('generator')}
                className={`px-4 py-2 rounded transition ${activeTab === 'generator' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}`}
              >
                Generator
              </button>
            </nav>
          </div>
        </div>
      </header>

      <div className="max-w-6xl mx-auto px-4 py-8">
        {activeTab === 'entries' ? (
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div className="lg:col-span-1 space-y-6">
              {!showForm ? (
                <>
                  <button
                    onClick={handleNewEntry}
                    className="w-full bg-blue-600 text-white py-3 rounded-md hover:bg-blue-700 transition font-medium"
                  >
                    + Add New Password
                  </button>
                  <div className="bg-white p-4 rounded-lg shadow">
                    <h3 className="font-semibold mb-2">Search</h3>
                    <input
                      type="text"
                      value={searchQuery}
                      onChange={(e) => setSearchQuery(e.target.value)}
                      placeholder="Search entries..."
                      className="w-full p-2 border rounded"
                    />
                  </div>
                </>
              ) : (
                <PasswordForm
                  entry={editingEntry}
                  onSave={handleSave}
                  onCancel={handleCancel}
                  existingNames={existingNames}
                />
              )}
            </div>

            <div className="lg:col-span-2">
              <PasswordList
                entries={filteredEntries}
                onEdit={handleEdit}
                onDelete={handleDelete}
              />
            </div>
          </div>
        ) : (
          <div className="max-w-xl mx-auto">
            <PasswordGenerator />
          </div>
        )}
      </div>
    </main>
  );
}
