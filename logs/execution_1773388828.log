import type { PasswordEntry, PasswordStrength } from '@/types';

const STORAGE_KEY = 'password-vault-entries';

export function getEntries(): PasswordEntry[] {
  if (typeof window === 'undefined') return [];
  
  try {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (!stored) return [];
    return JSON.parse(stored);
  } catch (e) {
    console.error('Failed to load entries:', e);
    return [];
  }
}

export function saveEntries(entries: PasswordEntry[]): void {
  if (typeof window === 'undefined') return;
  
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
  } catch (e) {
    console.error('Failed to save entries:', e);
  }
}

export function addEntry(
  entry: Omit<PasswordEntry, 'id' | 'createdAt' | 'updatedAt'>
): PasswordEntry {
  const entries = getEntries();
  
  // Check for duplicate names
  if (entries.some(e => e.name.toLowerCase() === entry.name.toLowerCase())) {
    throw new Error(`An entry named "${entry.name}" already exists`);
  }
  
  const newEntry: PasswordEntry = {
    ...entry,
    id: crypto.randomUUID(),
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  };
  
  saveEntries([...entries, newEntry]);
  return newEntry;
}

export function updateEntry(
  id: string,
  updates: Partial<Omit<PasswordEntry, 'id' | 'createdAt'>>
): PasswordEntry {
  const entries = getEntries();
  const index = entries.findIndex(e => e.id === id);
  
  if (index === -1) {
    throw new Error('Entry not found');
  }
  
  const updated: PasswordEntry = {
    ...entries[index]!,
    ...updates,
    updatedAt: new Date().toISOString(),
  };
  
  entries[index] = updated;
  saveEntries(entries);
  return updated;
}

export function deleteEntry(id: string): void {
  const entries = getEntries();
  saveEntries(entries.filter(e => e.id !== id));
}

export function getEntryById(id: string): PasswordEntry | undefined {
  return getEntries().find(e => e.id === id);
}

export function searchEntries(query: string): PasswordEntry[] {
  const lowerQuery = query.toLowerCase();
  return getEntries().filter(e =>
    e.name.toLowerCase().includes(lowerQuery) ||
    e.username.toLowerCase().includes(lowerQuery) ||
    e.url?.toLowerCase().includes(lowerQuery) ||
    e.tags?.some(t => t.toLowerCase().includes(lowerQuery))
  );
}

export function filterByTags(tags: string[]): PasswordEntry[] {
  return getEntries().filter(e =>
    tags.some(tag => e.tags?.includes(tag))
  );
}

export function getAllTags(): string[] {
  const entries = getEntries();
  const tagSet = new Set<string>();
  entries.forEach(e => e.tags?.forEach(tag => tagSet.add(tag)));
  return Array.from(tagSet).sort();
}

export function getStats(): {
  total: number;
  byStrength: Record<PasswordStrength, number>;
  byTag: Record<string, number>;
  averageAge: number;
} {
  const entries = getEntries();
  const now = Date.now();
  
  const byStrength: Record<PasswordStrength, number> = {
    weak: 0,
    fair: 0,
    good: 0,
    strong: 0,
    excellent: 0,
  };
  
  const byTag: Record<string, number> = {};
  
  let totalAge = 0;
  
  entries.forEach(e => {
    byStrength[e.strength]++;
    e.tags?.forEach(tag => {
      byTag[tag] = (byTag[tag] || 0) + 1;
    });
    
    const age = (now - new Date(e.createdAt).getTime()) / (1000 * 60 * 60 * 24);
    totalAge += age;
  });
  
  return {
    total: entries.length,
    byStrength,
    byTag,
    averageAge: entries.length > 0 ? totalAge / entries.length : 0,
  };
}
