'use client';

import { motion } from 'framer-motion';
import Card from './ui/Card';
import type { PasswordEntry } from '@/types';

interface Props {
  entries: PasswordEntry[];
}

export default function StatsDashboard({ entries }: Props) {
  const total = entries.length;
  const byStrength = entries.reduce((acc, e) => {
    acc[e.strength] = (acc[e.strength] || 0) + 1;
    return acc;
  }, {} as Record<string, number>);

  const avgEntropy = entries.reduce((sum, e) => {
    const pool = /[A-Z]/.test(e.password) ? 26 : 0 +
                 /[a-z]/.test(e.password) ? 26 : 0 +
                 /[0-9]/.test(e.password) ? 10 : 0 +
                 /[^A-Za-z0-9]/.test(e.password) ? 32 : 0;
    return sum + (e.password.length * Math.log2(pool || 1));
  }, 0) / (total || 1);

  const weakCount = (byStrength.weak || 0) + (byStrength.fair || 0);

  return (
    <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <Card className="p-4 text-center" animate>
        <motion.div
          key={total}
          initial={{ scale: 1.5 }}
          animate={{ scale: 1 }}
          className="text-3xl font-bold text-blue-600"
        >
          {total}
        </motion.div>
        <div className="text-sm text-gray-600">Total Passwords</div>
      </Card>

      <Card className="p-4 text-center" animate>
        <div className={`text-3xl font-bold ${weakCount > 0 ? 'text-yellow-600' : 'text-green-600'}`}>
          {weakCount}
        </div>
        <div className="text-sm text-gray-600">Need Review</div>
      </Card>

      <Card className="p-4 text-center" animate>
        <motion.div
          key={avgEntropy}
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          className="text-3xl font-bold text-purple-600"
        >
          {avgEntropy.toFixed(0)}
        </motion.div>
        <div className="text-sm text-gray-600">Avg Entropy (bits)</div>
      </Card>

      <Card className="p-4 text-center" animate>
        <div className="text-3xl font-bold text-emerald-600">
          {byStrength.excellent || 0}
        </div>
        <div className="text-sm text-gray-600">Excellent Strength</div>
      </Card>
    </div>
  );
}
