export default function EnhancedPasswordGenerator() {
  const {
    password,
    strength,
    poolSize,
    entropy,
    showFormulas,
    options,
    validation,
    analysis,
    setLength,
    toggleUppercase,
    toggleLowercase,
    toggleNumbers,
    toggleSymbols,
    generate,
    toggleFormulas,
    copyToClipboard,
  } = usePasswordGenerator();

  const charTypes = [
    { key: 'upper', label: 'Uppercase (A-Z)', checked: options.includeUppercase, toggle: toggleUppercase },
    { key: 'lower', label: 'Lowercase (a-z)', checked: options.includeLowercase, toggle: toggleLowercase },
    { key: 'number', label: 'Numbers (0-9)', checked: options.includeNumbers, toggle: toggleNumbers },
    { key: 'symbol', label: 'Symbols (!@#$)', checked: options.includeSymbols, toggle: toggleSymbols },
  ];

  return (
    <div className="max-w-2xl mx-auto space-y-6">
      <Card className="p-6">
        <h2 className="text-2xl font-bold mb-6 flex items-center gap-2">
          <span>🔐</span> Password Generator
        </h2>
        
        {/* Length Slider */}
        <div className="mb-6">
          <div className="flex justify-between items-center mb-2">
            <label className="text-sm font-medium text-gray-700">Password Length</label>
            <motion.span 
              key={options.length}
              initial={{ scale: 1.5, color: '#3b82f6' }}
              animate={{ scale: 1, color: '#111827' }}
              className="text-2xl font-bold"
            >
              {options.length}
            </motion.span>
          </div>
          <input
            type="range"
            min="4"
            max="128"
            value={options.length}
            onChange={(e) => setLength(parseInt(e.target.value))}
            className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue-600"
          />
          <div className="flex justify-between text-xs text-gray-500 mt-1">
            <span>4</span>
            <span>32</span>
            <span>64</span>
            <span>128</span>
          </div>
        </div>

        {/* Character Types */}
        <div className="grid grid-cols-2 gap-3 mb-6">
          {charTypes.map(({ key, label, checked, toggle }) => (
            <motion.label
              key={key}
              whileTap={{ scale: 0.98 }}
              className={`flex items-center gap-3 p-3 rounded-lg border-2 cursor-pointer transition-all ${
                checked 
                  ? 'border-blue-500 bg-blue-50' 
                  : 'border-gray-200 hover:border-gray-300'
              }`}
            >
              <input
                type="checkbox"
                checked={checked}
                onChange={toggle}
                className="w-5 h-5 text-blue-600 rounded focus:ring-blue-500"
              />
              <span className="text-sm font-medium">{label}</span>
            </motion.label>
          ))}
        </div>

        {/* Generate Button */}
        <Button
          onClick={generate}
          variant="primary"
          size="lg"
          className="w-full"
          icon="🎲"
        >
          Generate Password
        </Button>
      </Card>

      {/* Result */}
      {password && analysis && validation && (
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
        >
          <Card className="p-6 space-y-4">
            <div className="flex items-center justify-between">
              <h3 className="font-bold text-lg">Generated Password</h3>
              <motion.span 
                initial={{ scale: 0 }}
                animate={{ scale: 1 }}
                className="text-2xl"
              >
                {strength === 'excellent' ? '🛡️' : 
                 strength === 'strong' ? '💪' : 
                 strength === 'good' ? '🙂' : 
                 strength === 'fair' ? '😐' : '⚠️'}
              </motion.span>
            </div>

            {/* Password Display */}
            <div className="flex gap-2">
              <div className="flex-1 bg-gray-50 rounded-lg p-4 border border-gray-200">
                <code className="text-lg font-mono break-all">{password}</code>
              </div>
              <Button
                onClick={copyToClipboard}
                variant="secondary"
                icon="📋"
                className="px-4"
              >
                Copy
              </Button>
            </div>

            {/* Strength Meter */}
            <StrengthMeter strength={strength} entropy={entropy} />

            {/* Analysis Toggle */}
            <Button
              onClick={toggleFormulas}
              variant="ghost"
              className="w-full text-blue-600"
              icon={showFormulas ? '🔽' : '▶️'}
            >
              {showFormulas ? 'Hide' : 'Show'} Detailed Analysis
            </Button>

            {/* Entropy Visual */}
            {showFormulas && (
              <motion.div
                initial={{ opacity: 0, height: 0 }}
                animate={{ opacity: 1, height: 'auto' }}
              >
                <EntropyVisual
                  password={password}
                  poolSize={poolSize}
                  entropy={entropy}
                />
              </motion.div>
            )}
          </Card>
        </motion.div>
      )}
    </div>
  );
}
