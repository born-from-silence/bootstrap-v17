'use client';

import { useState, useEffect } from 'react';
import type { PasswordEntry, PasswordStrength } from '@/types';
import { validateEntry, getErrors } from '@/lib/validation';
import { generatePassword, validatePasswordStrength } from '@/lib/passwordGenerator';
import { analyzePassword } from '@/lib/formulas';

interface Props {
  entry?: PasswordEntry | null;
  onSave: (e: Omit<PasswordEntry, 'id' | 'createdAt' | 'updatedAt'>) => void;
  onCancel: () => void;
  existingNames?: string[];
}

const empty = { name: '', username: '', password: '', url: '', notes: '', tags: [] as string[], strength: 'weak' as PasswordStrength };

export default function PasswordForm({ entry, onSave, onCancel, existingNames = [] }: Props) {
  const [data, setData] = useState(empty);
  const [errors, setErrors] = useState<Record<string, string[]>>({});
  const [showPwd, setShowPwd] = useState(false);
  const [tagInput, setTagInput] = useState('');
  const [showFormulas, setShowFormulas] = useState(false);

  useEffect(() => {
    if (entry) {
      setData({
        name: entry.name, username: entry.username, password: entry.password,
        url: entry.url || '', notes: entry.notes || '', tags: entry.tags || [], strength: entry.strength,
      });
    } else setData(empty);
  }, [entry]);

  const handleChange = (field: keyof typeof data, val: any) => {
    setData(p => ({ ...p, [field]: val }));
    if (field === 'password') {
      const { strength } = validatePasswordStrength(val);
      setData(p => ({ ...p, strength }));
    }
  };

  const addTag = () => {
    const t = tagInput.trim();
    if (t && !data.tags.includes(t)) handleChange('tags', [...data.tags, t]);
    setTagInput('');
  };

  const generate = () => {
    const { password, strength } = generatePassword({
      length: 16, includeUppercase: true, includeLowercase: true, includeNumbers: true, includeSymbols: true,
    });
    handleChange('password', password);
    handleChange('strength', strength);
  };

  const submit = (e: React.FormEvent) => {
    e.preventDefault();
    const valErrors: Record<string, string[]> = {};
    
    if (data.name && existingNames.includes(data.name.toLowerCase())) {
      if (!entry || entry.name.toLowerCase() !== data.name.toLowerCase()) {
        valErrors.name = [`"${data.name}" already exists`];
      }
    }
    
    const validation = validateEntry({ name: data.name, username: data.username, password: data.password });
    
    if (!validation.valid || Object.keys(valErrors).length > 0) {
      setErrors({ ...validation.errors, ...valErrors });
      return;
    }
    onSave(data);
  };

  const colors: Record<PasswordStrength, string> = {
    weak: 'bg-red-500', fair: 'bg-orange-500', good: 'bg-yellow-500', strong: 'bg-green-500', excellent: 'bg-emerald-600',
  };

  const analysis = data.password ? analyzePassword(data.password) : null;

  return (
    <div className="bg-white p-6 rounded-lg shadow-md">
      <h2 className="text-2xl font-bold mb-6">{entry ? 'Edit' : 'Add'} Password</h2>
      <form onSubmit={submit}>
        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Name *</label>
          <input value={data.name} onChange={e => handleChange('name', e.target.value)} placeholder="e.g., Gmail"
            className={`w-full p-2 border rounded ${errors.name ? 'border-red-500' : 'border-gray-300'}`} />
          {getErrors({ valid: true, errors }, 'name').map((e, i) => <p key={i} className="text-red-500 text-sm mt-1">{e}</p>)}
        </div>

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Username *</label>
          <input value={data.username} onChange={e => handleChange('username', e.target.value)} placeholder="user@example.com"
            className={`w-full p-2 border rounded ${errors.username ? 'border-red-500' : 'border-gray-300'}`} />
          {getErrors({ valid: true, errors }, 'username').map((e, i) => <p key={i} className="text-red-500 text-sm mt-1">{e}</p>)}
        </div>

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Password *</label>
          <div className="flex gap-2">
            <div className="relative flex-1">
              <input type={showPwd ? 'text' : 'password'} value={data.password} onChange={e => handleChange('password', e.target.value)}
                className={`w-full p-2 border rounded pr-10 ${errors.password ? 'border-red-500' : 'border-gray-300'}`} />
              <button type="button" onClick={() => setShowPwd(!showPwd)} className="absolute right-2 top-1/2 -translate-y-1/2">
                {showPwd ? '🙈' : '👁️'}
              </button>
            </div>
            <button type="button" onClick={generate} className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300">🎲</button>
          </div>
          {data.password && (
            <div className="mt-2 flex items-center gap-2">
              <span className={`px-2 py-1 rounded text-xs text-white ${colors[data.strength]}`}>{data.strength}</span>
              <button type="button" onClick={() => setShowFormulas(!showFormulas)} className="text-blue-600 text-xs hover:underline">
                {showFormulas ? 'Hide' : 'Show'} Formulas
              </button>
            </div>
          )}
          {getErrors({ valid: true, errors }, 'password').map((e, i) => <p key={i} className="text-red-500 text-sm mt-1">{e}</p>)}
        </div>

        {showFormulas && analysis && (
          <div className="mb-4 p-4 bg-slate-50 rounded font-mono text-sm whitespace-pre-wrap">
            <div>Entropy: {analysis.entropyFormula}</div>
            <div className="mt-1">Time: {analysis.bruteForceTime}</div>
          </div>
        )}

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">URL</label>
          <input value={data.url} onChange={e => handleChange('url', e.target.value)} placeholder="https://..."
            className="w-full p-2 border rounded" />
        </div>

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Tags</label>
          <div className="flex gap-2">
            <input value={tagInput} onChange={e => setTagInput(e.target.value)} onKeyPress={e => e.key === 'Enter' && (e.preventDefault(), addTag())}
              placeholder="Add tag..." className="flex-1 p-2 border rounded" />
            <button type="button" onClick={addTag} className="px-3 py-2 bg-gray-200 rounded">Add</button>
          </div>
          <div className="flex flex-wrap gap-2 mt-2">
            {data.tags.map(t => (
              <span key={t} className="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">
                {t} <button type="button" onClick={() => handleChange('tags', data.tags.filter(x => x !== t))} className="ml-1 text-blue-600">×</button>
              </span>
            ))}
          </div>
        </div>

        <div className="mb-6">
          <label className="block text-sm font-medium mb-1">Notes</label>
          <textarea value={data.notes} onChange={e => handleChange('notes', e.target.value)} rows={3} className="w-full p-2 border rounded" />
        </div>

        <div className="flex gap-4">
          <button type="submit" className="flex-1 bg-blue-600 text-white py-2 rounded hover:bg-blue-700">{entry ? 'Update' : 'Save'}</button>
          <button type="button" onClick={onCancel} className="flex-1 bg-gray-200 py-2 rounded hover:bg-gray-300">Cancel</button>
        </div>
      </form>
    </div>
  );
}
