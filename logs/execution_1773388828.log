'use client';

import { useState, useEffect } from 'react';
import type { PasswordEntry, PasswordStrength } from '@/types';
import { validateEntry, getFieldErrors } from '@/lib/validation';
import { generatePassword } from '@/lib/passwordGenerator';
import { analyzePassword } from '@/lib/formulas';

interface PasswordFormProps {
  entry?: PasswordEntry | null;
  onSave: (entry: Omit<PasswordEntry, 'id' | 'createdAt' | 'updatedAt'>) => void;
  onCancel: () => void;
  existingNames?: string[];
}

const emptyEntry = {
  name: '',
  username: '',
  password: '',
  url: '',
  notes: '',
  tags: [] as string[],
  strength: 'weak' as PasswordStrength,
};

export default function PasswordForm({ entry, onSave, onCancel, existingNames = [] }: PasswordFormProps) {
  const [formData, setFormData] = useState(emptyEntry);
  const [errors, setErrors] = useState<Record<string, string[]>>({});
  const [showPassword, setShowPassword] = useState(false);
  const [tagInput, setTagInput] = useState('');
  const [showFormulas, setShowFormulas] = useState(false);

  useEffect(() => {
    if (entry) {
      setFormData({
        name: entry.name,
        username: entry.username,
        password: entry.password,
        url: entry.url || '',
        notes: entry.notes || '',
        tags: entry.tags || [],
        strength: entry.strength,
      });
    } else {
      setFormData(emptyEntry);
    }
  }, [entry]);

  const handleChange = (field: keyof typeof formData, value: any) => {
    setFormData(prev => ({ ...prev, [field]: value }));
    if (errors[field]) {
      setErrors(prev => { const n = {...prev}; delete n[field]; return n; });
    }
    if (field === 'password') {
      const { strength } = validatePasswordStrength(value);
      setFormData(prev => ({ ...prev, strength }));
    }
  };

  const handleAddTag = () => {
    const trimmed = tagInput.trim();
    if (trimmed && !formData.tags.includes(trimmed)) {
      handleChange('tags', [...formData.tags, trimmed]);
      setTagInput('');
    }
  };

  const handleGeneratePassword = () => {
    try {
      const { password, strength } = generatePassword({
        length: 16,
        includeUppercase: true,
        includeLowercase: true,
        includeNumbers: true,
        includeSymbols: true,
      });
      handleChange('password', password);
      handleChange('strength', strength);
    } catch {}
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    const validationErrors: Record<string, string[]> = {};
    
    if (formData.name && existingNames.includes(formData.name.toLowerCase())) {
      if (!entry || entry.name.toLowerCase() !== formData.name.toLowerCase()) {
        validationErrors.name = [`An entry named "${formData.name}" already exists`];
      }
    }
    
    const validation = validateEntry({
      name: formData.name,
      username: formData.username,
      password: formData.password,
    });
    
    if (!validation.valid || Object.keys(validationErrors).length > 0) {
      setErrors({ ...validation.errors, ...validationErrors });
      return;
    }

    onSave(formData);
  };

  const strengthColors: Record<PasswordStrength, string> = {
    weak: 'bg-red-500 text-white',
    fair: 'bg-orange-500 text-white',
    good: 'bg-yellow-500 text-black',
    strong: 'bg-green-500 text-white',
    excellent: 'bg-emerald-600 text-white',
  };

  const analysis = formData.password ? analyzePassword(formData.password) : null;

  return (
    <div className="bg-white p-6 rounded-lg shadow-md">
      <h2 className="text-2xl font-bold mb-6">{entry ? 'Edit Entry' : 'Add New Password'}</h2>

      <form onSubmit={handleSubmit}>
        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Name *</label>
          <input
            type="text"
            value={formData.name}
            onChange={(e) => handleChange('name', e.target.value)}
            placeholder="e.g., Gmail"
            className={`w-full p-2 border rounded-md ${errors.name ? 'border-red-500' : 'border-gray-300'}`}
          />
          {getFieldErrors({ valid: true, errors }, 'name').map((err, i) => (
            <p key={i} className="text-red-500 text-sm mt-1">{err}</p>
          ))}
        </div>

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Username *</label>
          <input
            type="text"
            value={formData.username}
            onChange={(e) => handleChange('username', e.target.value)}
            placeholder="user@example.com"
            className={`w-full p-2 border rounded-md ${errors.username ? 'border-red-500' : 'border-gray-300'}`}
          />
          {getFieldErrors({ valid: true, errors }, 'username').map((err, i) => (
            <p key={i} className="text-red-500 text-sm mt-1">{err}</p>
          ))}
        </div>

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Password *</label>
          <div className="flex gap-2">
            <div className="relative flex-1">
              <input
                type={showPassword ? 'text' : 'password'}
                value={formData.password}
                onChange={(e) => handleChange('password', e.target.value)}
                className={`w-full p-2 border rounded-md pr-10 ${errors.password ? 'border-red-500' : 'border-gray-300'}`}
              />
              <button
                type="button"
                onClick={() => setShowPassword(!showPassword)}
                className="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500"
              >
                {showPassword ? '🙈' : '👁️'}
              </button>
            </div>
            <button type="button" onClick={handleGeneratePassword} className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300">🎲</button>
          </div>
          
          {formData.password && (
            <div className="mt-2 flex items-center gap-2">
              <span className={`px-2 py-1 rounded text-xs ${strengthColors[formData.strength]}`}>
                {formData.strength.charAt(0).toUpperCase() + formData.strength.slice(1)}
              </span>
              <button type="button" onClick={() => setShowFormulas(!showFormulas)} className="text-blue-600 text-xs hover:underline">
                {showFormulas ? 'Hide' : 'Show'} Formulas
              </button>
            </div>
          )}
          
          {getFieldErrors({ valid: true, errors }, 'password').map((err, i) => (
            <p key={i} className="text-red-500 text-sm mt-1">{err}</p>
          ))}
        </div>

        {showFormulas && analysis && (
          <div className="mb-4 p-4 bg-slate-50 rounded-lg overflow-x-auto border text-sm font-mono">
            <div className="text-gray-600 mb-2">Entropy: {analysis.entropyFormula}</div>
            <div>Time to Crack: {analysis.bruteForceFormula}</div>
          </div>
        )}

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">URL (optional)</label>
          <input
            type="text"
            value={formData.url}
            onChange={(e) => handleChange('url', e.target.value)}
            placeholder="https://example.com"
            className="w-full p-2 border rounded-md border-gray-300"
          />
        </div>

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Tags</label>
          <div className="flex gap-2">
            <input
              type="text"
              value={tagInput}
              onChange={(e) => setTagInput(e.target.value)}
              onKeyPress={(e) => e.key === 'Enter' && (e.preventDefault(), handleAddTag())}
              placeholder="Add tag..."
              className="flex-1 p-2 border rounded-md border-gray-300"
            />
            <button type="button" onClick={handleAddTag} className="px-3 py-2 bg-gray-200 rounded hover:bg-gray-300">Add</button>
          </div>
          <div className="flex flex-wrap gap-2 mt-2">
            {formData.tags.map(tag => (
              <span key={tag} className="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">
                {tag}
                <button type="button" onClick={() => handleChange('tags', formData.tags.filter(t => t !== tag))} className="ml-1 text-blue-600 hover:text-red-500">×</button>
              </span>
            ))}
          </div>
        </div>

        <div className="mb-6">
          <label className="block text-sm font-medium mb-1">Notes</label>
          <textarea
            value={formData.notes}
            onChange={(e) => handleChange('notes', e.target.value)}
            rows={3}
            className="w-full p-2 border rounded-md border-gray-300"
          />
        </div>

        <div className="flex gap-4">
          <button type="submit" className="flex-1 bg-blue-600 text-white py-2 rounded-md hover:bg-blue-700">
            {entry ? 'Update' : 'Save'} Entry
          </button>
          <button type="button" onClick={onCancel} className="flex-1 bg-gray-200 text-gray-800 py-2 rounded-md hover:bg-gray-300">
            Cancel
          </button>
        </div>
      </form>
    </div>
  );
}
