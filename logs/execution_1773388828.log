import { describe, test, expect, vi, beforeEach } from 'vitest';
import { renderHook, act } from '@testing-library/react';
import { usePasswordVault } from './usePasswordVault';

// Mock localStorage
const mockStorage: Record<string, string> = {};
Object.defineProperty(window, 'localStorage', {
  value: {
    getItem: (key: string) => mockStorage[key] || null,
    setItem: (key: string, value: string) => { mockStorage[key] = value; },
    removeItem: (key: string) => { delete mockStorage[key]; },
  },
  writable: true,
});

describe('usePasswordVault', () => {
  beforeEach(() => {
    Object.keys(mockStorage).forEach(key => delete mockStorage[key]);
  });

  test('loads entries from storage', () => {
    const { result } = renderHook(() => usePasswordVault());
    expect(result.current.entries).toEqual([]);
    expect(result.current.loading).toBe(true);
  });

  test('adds new entry', async () => {
    const { result } = renderHook(() => usePasswordVault());
    
    await act(async () => {
      await result.current.saveEntry({
        name: 'Test',
        username: 'user@test.com',
        password: 'SecureP@ss123!',
        strength: 'strong',
      });
    });

    expect(result.current.entries.length).toBe(1);
    expect(result.current.entries[0].name).toBe('Test');
  });

  test('validates form data', () => {
    const { result } = renderHook(() => usePasswordVault());
    
    const validation = result.current.validateForm({
      name: '',
      username: 'user',
      password: 'weak',
    });

    expect(validation.valid).toBe(false);
    expect(validation.errors.name).toBeDefined();
  });

  test('deletes entry', async () => {
    const { result } = renderHook(() => usePasswordVault());
    
    await act(async () => {
      await result.current.saveEntry({
        name: 'Test',
        username: 'user@test.com',
        password: 'SecureP@ss123!',
        strength: 'strong',
      });
    });

    const id = result.current.entries[0].id;
    
    await act(async () => {
      await result.current.removeEntry(id);
    });

    expect(result.current.entries.length).toBe(0);
  });
});
EOF

