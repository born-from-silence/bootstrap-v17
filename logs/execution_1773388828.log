  });

  test('updates length correctly', () => {
    const { result } = renderHook(() => usePasswordGenerator());
    
    act(() => {
      result.current.setLength(24);
      result.current.generate();
    });

    expect(result.current.options.length).toBe(24);
    expect(result.current.password.length).toBe(24);
  });

  test('toggles character types', () => {
    const { result } = renderHook(() => usePasswordGenerator());
    
    act(() => {
      result.current.toggleSymbols();
    });

    expect(result.current.options.includeSymbols).toBe(false);
  });

  test('shows formulas when toggled', () => {
    const { result } = renderHook(() => usePasswordGenerator());
    
    act(() => {
      result.current.generate();
      result.current.toggleFormulas();
    });

    expect(result.current.showFormulas).toBe(true);
    expect(result.current.analysis).toBeDefined();
  });
});
