import { calculatePoolSize } from './passwordGenerator';

export interface FormulaData {
  entropy: number;
  entropyFormula: string;
  bruteForceTime: string;
  bruteForceFormula: string;
  classification: string;
  securityAssessment: string;
  password: string;
  poolSize: number;
  length: number;
}

export function analyzePassword(password: string): FormulaData {
  const poolSize = calculatePoolSize(password);
  const length = password.length;
  const entropy = length * Math.log2(poolSize);
  
  return {
    password,
    poolSize,
    length,
    entropy,
    entropyFormula: generateEntropyFormula(password, poolSize, entropy),
    bruteForceTime: calculateBruteForceTime(password, 1e9),
    bruteForceFormula: generateBruteForceFormula(password, 1e9),
    classification: getStrengthClassification(entropy),
    securityAssessment: getSecurityAssessment(password),
  };
}

export function generateEntropyFormula(password: string, poolSize: number, entropy: number): string {
  const log2N = Math.log2(poolSize).toFixed(2);
  return `S = L \\cdot \\log_2(N) = ${password.length} \\cdot \\log_2(${poolSize}) = ${password.length} \\cdot ${log2N} = ${entropy.toFixed(2)} \\text{ bits}`;
}

export function generateBruteForceFormula(password: string, attemptsPerSecond: number = 1e9): string {
  const poolSize = calculatePoolSize(password);
  const combinations = Math.pow(poolSize, password.length);
  const seconds = combinations / attemptsPerSecond;
  
  return `T = \\frac{N^L}{R} = \\frac{${poolSize}^{${password.length}}}{${attemptsPerSecond.toExponential(1)}} \\approx ${formatTime(seconds)}`;
}

export function calculateBruteForceTime(password: string, attemptsPerSecond: number = 1e9): string {
  const poolSize = calculatePoolSize(password);
  if (poolSize === 1) return 'instantly';
  
  const combinations = Math.pow(poolSize, password.length);
  const seconds = combinations / attemptsPerSecond;
  return formatTime(seconds);
}

export function getStrengthClassification(entropy: number): string {
  if (entropy < 40) {
    return 'Weak: $< 40$ bits. Crackable in seconds to minutes.';
  } else if (entropy < 60) {
    return 'Fair: $40\\text{--}60$ bits. Crackable in hours to days.';
  } else if (entropy < 80) {
    return 'Good: $60\\text{--}80$ bits. Crackable in months to years.';
  } else if (entropy < 100) {
    return 'Strong: $80\\text{--}100$ bits. Crackable in decades to centuries.';
  } else {
    return 'Excellent: $\\geq 100$ bits. Practically uncrackable.';
  }
}

export function getSecurityAssessment(password: string): string {
  const poolSize = calculatePoolSize(password);
  const combinations = Math.pow(poolSize, password.length);
  const seconds = combinations / 1e9;
  
  if (seconds < 60) return '\\text{CRITICAL}: Crackable in under a minute!';
  if (seconds < 86400) return '\\text{WARNING}: Crackable within a day.';
  if (seconds < 31536000) return '\\text{MODERATE}: Crackable within a year.';
  if (seconds < 315360000) return '\\text{GOOD}: Would take over a decade.';
  return '\\text{EXCELLENT}: Would take over a century.';
}

function formatTime(seconds: number): string {
  if (seconds < 1) return `${(seconds * 1000).toFixed(0)} \\text{ ms}`;
  if (seconds < 60) return `${seconds.toFixed(0)} \\text{ s}`;
  if (seconds < 3600) return `${(seconds / 60).toFixed(1)} \\text{ min}`;
  if (seconds < 86400) return `${(seconds / 3600).toFixed(1)} \\text{ hr}`;
  if (seconds < 31536000) return `${(seconds / 86400).toFixed(1)} \\text{ days}`;
  if (seconds < 3153600000) return `${(seconds / 31536000).toFixed(1)} \\text{ yr}`;
  return `${(seconds / 3153600000).toFixed(1)} \\text{ centuries}`;
}

export function generateCompleteAnalysis(password: string): string {
  const data = analyzePassword(password);
  
  return `\\begin{aligned}
&\\textbf{Password Entropy} \\\\
& ${data.entropyFormula} \\\\
\\
&\\textbf{Brute Force Time} \\\\
& ${data.bruteForceFormula} \\\\
\\
&\\textbf{Classification:} ${data.classification} \\\\
\\
&\\textbf{Assessment:} ${data.securityAssessment}
\\end{aligned}`;
}
