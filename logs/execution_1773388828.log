'use client';

import { useState } from 'react';
import { generatePassword, validatePasswordStrength } from '@/lib/passwordGenerator';
import { analyzePassword } from '@/lib/formulas';

interface PasswordGeneratorProps {
  onPasswordGenerated?: (password: string, strength: string) => void;
}

export default function PasswordGenerator({ onPasswordGenerated }: PasswordGeneratorProps) {
  const [length, setLength] = useState(16);
  const [includeUppercase, setIncludeUppercase] = useState(true);
  const [includeLowercase, setIncludeLowercase] = useState(true);
  const [includeNumbers, setIncludeNumbers] = useState(true);
  const [includeSymbols, setIncludeSymbols] = useState(true);
  const [generatedPassword, setGeneratedPassword] = useState('');
  const [strength, setStrength] = useState<string>('');
  const [showFormulas, setShowFormulas] = useState(false);

  const handleGenerate = () => {
    try {
      const result = generatePassword({
        length,
        includeUppercase,
        includeLowercase,
        includeNumbers,
        includeSymbols,
      });
      
      setGeneratedPassword(result.password);
      setStrength(result.strength);
      onPasswordGenerated?.(result.password, result.strength);
    } catch (e) {
      alert(e instanceof Error ? e.message : 'Failed to generate');
    }
  };

  const strengthColors: Record<string, string> = {
    weak: 'bg-red-500',
    fair: 'bg-orange-500',
    good: 'bg-yellow-500',
    strong: 'bg-green-500',
    excellent: 'bg-emerald-600',
  };

  const analysis = generatedPassword ? analyzePassword(generatedPassword) : null;

  return (
    <div className="bg-white p-6 rounded-lg shadow-md">
      <h2 className="text-2xl font-bold mb-6">Password Generator</h2>
      
      <div className="mb-4">
        <label className="block text-sm font-medium mb-2">
          Password Length: <span className="font-bold">{length}</span>
        </label>
        <input
          type="range"
          min="4"
          max="128"
          value={length}
          onChange={(e) => setLength(parseInt(e.target.value))}
          className="w-full"
        />
      </div>

      <div className="grid grid-cols-2 gap-4 mb-6">
        <label className="flex items-center space-x-2">
          <input type="checkbox" checked={includeUppercase} onChange={(e) => setIncludeUppercase(e.target.checked)} className="w-4 h-4" />
          <span>Uppercase (A-Z)</span>
        </label>
        <label className="flex items-center space-x-2">
          <input type="checkbox" checked={includeLowercase} onChange={(e) => setIncludeLowercase(e.target.checked)} className="w-4 h-4" />
          <span>Lowercase (a-z)</span>
        </label>
        <label className="flex items-center space-x-2">
          <input type="checkbox" checked={includeNumbers} onChange={(e) => setIncludeNumbers(e.target.checked)} className="w-4 h-4" />
          <span>Numbers (0-9)</span>
        </label>
        <label className="flex items-center space-x-2">
          <input type="checkbox" checked={includeSymbols} onChange={(e) => setIncludeSymbols(e.target.checked)} className="w-4 h-4" />
          <span>Symbols (!@#$)</span>
        </label>
      </div>

      <button
        onClick={handleGenerate}
        className="w-full bg-blue-600 text-white py-3 rounded-md hover:bg-blue-700 transition font-medium"
      >
        Generate Password
      </button>

      {generatedPassword && (
        <div className="mt-6">
          <div className="flex items-center gap-2 mb-2">
            <span className={`px-2 py-1 rounded text-white text-sm ${strengthColors[strength]}`}>
              {strength.charAt(0).toUpperCase() + strength.slice(1)}
            </span>
          </div>
          <div className="flex gap-2">
            <input
              type="text"
              value={generatedPassword}
              readOnly
              className="flex-1 p-3 border rounded-md font-mono bg-gray-50"
            />
            <button
              onClick={() => navigator.clipboard.writeText(generatedPassword)}
              className="px-4 py-2 bg-gray-200 rounded-md hover:bg-gray-300"
              title="Copy"
            >
              📋
            </button>
          </div>

          <button
            onClick={() => setShowFormulas(!showFormulas)}
            className="mt-4 text-blue-600 hover:underline"
          >
            {showFormulas ? 'Hide Formulas' : 'Show MathJax Formulas'}
          </button>

          {showFormulas && analysis && (
            <div className="mt-4 p-4 bg-slate-50 rounded-lg overflow-x-auto">
              <div className="text-sm text-gray-600 mb-2">Entropy Formula:</div>
              <div className="font-mono text-sm mb-4">{analysis.entropyFormula}</div>
              <div className="text-sm text-gray-600 mb-2">Brute Force Time:</div>
              <div className="font-mono text-sm">{analysis.bruteForceFormula}</div>
              <div className="mt-4 text-sm">
                <strong>Classification:</strong> {analysis.classification}
              </div>
              <div className="mt-2 text-sm">
                <strong>Assessment:</strong> {analysis.securityAssessment}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  );
}
