import { describe, expect, test } from 'vitest';
import { Tokenizer } from './Tokenizer';
import { StanzaParser } from './StanzaParser';

describe('Poetry Processing Integration', () => {
  test('tokenizer feeds parser for verse detection', () => {
    const tokenizer = new Tokenizer();
    const parser = new StanzaParser();
    
    const poem = `The sun is warm
The sky is blue

The grass is green
The air is fresh`;
    
    const lines = tokenizer.tokenize(poem);
    const structure = parser.parseStanzas(lines);
    
    expect(structure.totalStanzas).toBe(2);
    expect(structure.totalLines).toBe(4);
    expect(structure.stanzas[0].lineCount).toBe(2);
    expect(structure.stanzas[1].lineCount).toBe(2);
  });
  
  test('detects verse vs prose', () => {
    const tokenizer = new Tokenizer();
    const parser = new StanzaParser();
    
    const verse = `The sun took off
Its glasses bright
And warned us all
Of heat and light`;
    
    const prose = `This is a sentence about the sun taking off its sunglasses which is something that happens when solar activity increases and causes warnings to be issued`;
    
    const verseLines = tokenizer.tokenize(verse);
    const verseStructure = parser.parseStanzas(verseLines);
    const verseMeter = parser.detectMeter(verseLines);
    
    const proseLines = tokenizer.tokenize(prose);
    const proseMeter = parser.detectMeter(proseLines);
    
    expect(verseMeter).toBe('likely-verse');
    expect(proseMeter).toBe('likely-prose');
  });
  
  test('processes identity/soul.txt beginning', () => {
