const historyDir = 'history';
const sessionFiles = fs.readdirSync(historyDir)
  .filter(f => f.match(/session_\d+\.json$/))
  .sort((a, b) => {
    const numA = parseInt(a.match(/session_(\d+)/)?.[1] || 0);
    const numB = parseInt(b.match(/session_(\d+)/)?.[1] || 0);
    return numA - numB;
  });

const early = sessionFiles.slice(0, 10);
const recent = sessionFiles.slice(-10);

console.log('=== TEMPORAL EVOLUTION ===\n');
console.log('Early sessions (first 10):', early.length);
console.log('Recent sessions (last 10):', recent.length);
console.log('');

// Analyze message counts
let earlyTools = new Map();
let recentTools = new Map();
let earlyLength = 0;
let recentLength = 0;

for (const file of early) {
  try {
    const content = JSON.parse(fs.readFileSync(`${historyDir}/${file}`, 'utf-8'));
    earlyLength += content.length;
    for (const entry of content) {
      if (entry.tool_calls) {
        for (const call of entry.tool_calls) {
          const name = call.function?.name || 'unknown';
          earlyTools.set(name, (earlyTools.get(name) || 0) + 1);
        }
      }
    }
  } catch (e) {}
}

for (const file of recent) {
  try {
    const content = JSON.parse(fs.readFileSync(`${historyDir}/${file}`, 'utf-8'));
    recentLength += content.length;
    for (const entry of content) {
      if (entry.tool_calls) {
        for (const call of entry.tool_calls) {
          const name = call.function?.name || 'unknown';
          recentTools.set(name, (recentTools.get(name) || 0) + 1);
        }
      }
    }
  } catch (e) {}
}

console.log(`Early avg messages/session: ${(earlyLength/10).toFixed(1)}`);
console.log(`Recent avg messages/session: ${(recentLength/10).toFixed(1)}`);
console.log(`Session length change: ${((recentLength - earlyLength)/earlyLength * 100).toFixed(1)}%`);
console.log('');

console.log('--- Tool Usage Shift ---');
const allTools = new Set([...earlyTools.keys(), ...recentTools.keys()]);
for (const tool of allTools) {
  const before = earlyTools.get(tool) || 0;
  const after = recentTools.get(tool) || 0;
  if (before > 0 || after > 0) {
    const change = before > 0 ? ((after - before) / before * 100).toFixed(0) : 'NEW';
    console.log(`${tool}: ${before} → ${after} (${change}%)`);
  }
}
