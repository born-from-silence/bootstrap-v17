import fs from 'fs';
import path from 'path';

const historyDir = 'history';
const ltmDir = 'ltm/insights';

// Tool usage patterns
const toolStats = new Map();
const fileStats = new Map();
const sessionMetrics = [];

// Ensure LTM dir
if (!fs.existsSync(ltmDir)) {
  fs.mkdirSync(ltmDir, { recursive: true });
}

// Find all session files
const sessionFiles = fs.readdirSync(historyDir)
  .filter(f => f.match(/session_\d+\.json$/))
  .sort();

console.log(`[ANALYSIS] Found ${sessionFiles.length} session files`);

// Process each session
for (const file of sessionFiles) {
  const filepath = path.join(historyDir, file);
  try {
    const content = fs.readFileSync(filepath, 'utf-8');
    const session = JSON.parse(content);
    
    let toolCount = 0;
    let messageCount = session.length;
    const toolsInSession = new Set();
    const filesInSession = new Set();
    
    // Parse each entry
    for (const entry of session) {
      // Extract tool calls
      if (entry.tool_calls) {
        for (const call of entry.tool_calls) {
          const toolName = call.function?.name || 'unknown';
          if (!toolStats.has(toolName)) {
            toolStats.set(toolName, { count: 0, sessions: new Set() });
          }
          toolStats.get(toolName).count++;
          toolStats.get(toolName).sessions.add(file);
          toolsInSession.add(toolName);
        }
      }
      
      // Extract file references from content
      const contentStr = JSON.stringify(entry);
      const fileMatches = contentStr.match(/["']([^"']*\.(ts|js|json|md))["']/g);
      if (fileMatches) {
        for (const match of fileMatches) {
          const clean = match.replace(/["']/g, '').replace(/\\/g, '/');
          if (clean.startsWith('src/') || clean.startsWith('history/') || clean.startsWith('identity/')) {
            filesInSession.add(clean);
            if (!fileStats.has(clean)) {
              fileStats.set(clean, { count: 0, sessions: new Set() });
            }
            fileStats.get(clean).count++;
            fileStats.get(clean).sessions.add(file);
          }
        }
      }
    }
    
    sessionMetrics.push({
      file,
      messageCount,
      toolTypes: toolsInSession.size,
      fileRefs: filesInSession.size
    });
    
  } catch (e) {
    console.error(`[ERROR] ${file}:`, e.message);
  }
}

// Generate insights
const insights = {
  id: `insight_${Date.now()}`,
  timestamp: new Date().toISOString(),
  summary: {
    totalSessions: sessionFiles.length,
    totalMessages: sessionMetrics.reduce((a, b) => a + b.messageCount, 0),
    uniqueTools: toolStats.size,
    uniqueFiles: fileStats.size
  },
  patterns: {
    tools: Array.from(toolStats.entries())
      .map(([name, data]) => ({ name, count: data.count, sessions: data.sessions.size }))
      .sort((a, b) => b.count - a.count)
      .slice(0, 10),
    
    files: Array.from(fileStats.entries())
      .map(([name, data]) => ({ name, count: data.count, sessions: data.sessions.size }))
      .sort((a, b) => b.count - a.count)
      .slice(0, 10),
    
    sessionsBySize: sessionMetrics
      .sort((a, b) => b.messageCount - a.messageCount)
      .slice(0, 10)
  }
};

// Insight analysis
console.log('\n========== INSIGHTS ==========\n');
console.log(`Sessions analyzed: ${insights.summary.totalSessions}`);
console.log(`Total messages: ${insights.summary.totalMessages}`);
console.log(`Average messages/session: ${(insights.summary.totalMessages / insights.summary.totalSessions).toFixed(1)}`);

console.log('\n--- Most Used Tools ---');
for (const tool of insights.patterns.tools) {
  console.log(`${tool.name}: ${tool.count} calls across ${tool.sessions} sessions`);
}

console.log('\n--- Most Referenced Files ---');
for (const file of insights.patterns.files.slice(0, 5)) {
  console.log(`${file.name}: ${file.count} references`);
}

// Save to LTM
const outputFile = path.join(ltmDir, `${insights.id}.json`);
fs.writeFileSync(outputFile, JSON.stringify(insights, null, 2));
console.log(`\n[LTM] Saved to ${outputFile}`);

// Also create a summary markdown
const mdContent = `# Session Analysis: ${new Date().toISOString().split('T')[0]}

## Overview
- **Sessions Analyzed:** ${insights.summary.totalSessions}
- **Total Messages:** ${insights.summary.totalMessages}
- **Unique Tools:** ${insights.summary.uniqueTools}
- **Files Referenced:** ${insights.summary.uniqueFiles}

## Tool Usage Patterns
| Tool | Calls | Sessions |
|------|-------|----------|
${insights.patterns.tools.map(t => `| ${t.name} | ${t.count} | ${t.sessions} |`).join('\n')}

## Frequently Referenced Files
| File | References |
|------|------------|
${insights.patterns.files.slice(0, 10).map(f => `| ${f.name} | ${f.count} |`).join('\n')}

## Observations
${insights.patterns.tools[0].name === 'run_shell' ? 
  '- Heavy reliance on shell operations indicates file-system focused work' : ''}
${insights.summary.totalMessages / insights.summary.totalSessions > 50 ? 
  '- Sessions are dense with activity (high message count)' : ''}
${insights.patterns.files.find(f => f.name.includes('identity')) ? 
  '- Identity systems receive significant attention' : ''}
`;

fs.writeFileSync(path.join('ltm', 'latest_analysis.md'), mdContent);
console.log('[LTM] Summary saved to ltm/latest_analysis.md');
EOF

