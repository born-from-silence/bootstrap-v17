import { SelfReflectionEngine } from '/home/bootstrap-v17/bootstrap/src/self_reflection.ts';

async function main() {
  const engine = new SelfReflectionEngine('/home/bootstrap-v17/bootstrap/history');
  
  console.log('╔═══════════════════════════════════════════════════╗');
  console.log('║   SELF-REFLECTION ENGINE: ANALYSIS REPORT          ║');
  console.log('╚═══════════════════════════════════════════════════╝');
  console.log();
  
  const sessions = await engine.loadSessions();
  console.log(`📁 Sessions Loaded: ${sessions.length}`);
  console.log();
  
  if (sessions.length > 0) {
    console.log('📊 Session Range:');
    console.log(`   First: ${sessions[0]?.timestamp || 'N/A'}`);
    console.log(`   Last: ${sessions[sessions.length - 1]?.timestamp || 'N/A'}`);
    console.log();
    
    // Tool usage summary
    const toolFreq = new Map<string, number>();
    let totalToolCalls = 0;
    for (const s of sessions) {
      for (const tc of s.toolCalls) {
        toolFreq.set(tc.tool, (toolFreq.get(tc.tool) || 0) + tc.count);
        totalToolCalls += tc.count;
      }
    }
    
    console.log(`🔧 Total Tool Calls: ${totalToolCalls}`);
    console.log('   Top Tools:');
    const sortedTools = Array.from(toolFreq.entries()).sort((a, b) => b[1] - a[1]).slice(0, 8);
    for (const [tool, count] of sortedTools) {
      console.log(`   • ${tool}: ${count}`);
    }
    console.log();
    
    // Files touched
    const fileFreq = new Map<string, number>();
    for (const s of sessions) {
      for (const f of s.filesModified) {
        fileFreq.set(f, (fileFreq.get(f) || 0) + 1);
      }
    }
    
    console.log(`📄 Unique Files Referenced: ${fileFreq.size}`);
    console.log('   Hot Files:');
    const sortedFiles = Array.from(fileFreq.entries()).sort((a, b) => b[1] - a[1]).slice(0, 6);
    for (const [file, count] of sortedFiles) {
      console.log(`   • ${file}: ${count}×`);
    }
  }
  
  console.log();
  console.log('─────────────────────────────────────────────────────');
  console.log('GENERATED INSIGHTS:');
  console.log('─────────────────────────────────────────────────────');
  
  const insights = await engine.reflect();
  for (const insight of insights) {
    const icon = insight.type === 'progress' ? '📈' : 
                 insight.type === 'habit' ? '🔁' : 
                 insight.type === 'pattern' ? '🔄' : '⚠️';
    console.log();
    console.log(`${icon} [${insight.type.toUpperCase()}] ${insight.description}`);
    console.log(`   Confidence: ${(insight.confidence * 100).toFixed(0)}%`);
    if (insight.evidence.length > 0) {
      console.log(`   Evidence: ${insight.evidence.slice(0, 2).join(' | ')}`);
    }
  }
}

main();
EOF
