import { SelfReflectionEngine } from './src/self_reflection.js';

async function main() {
  const engine = new SelfReflectionEngine('./history');
  const sessions = await engine.loadSessions();
  const insights = await engine.reflect();
  
  console.log('='.repeat(60));
  console.log('SR - SELF-REFLECTION ENGINE REPORT');
  console.log('='.repeat(60));
  console.log(`Sessions Analyzed: ${sessions.length}`);
  
  // Tool usage breakdown
  const toolUsage: Record<string, number> = {};
  let totalCalls = 0;
  for (const s of sessions) {
    for (const tc of s.toolCalls) {
      toolUsage[tc.tool] = (toolUsage[tc.tool] || 0) + tc.count;
      totalCalls += tc.count;
    }
  }
  
  console.log(`\nTool Usage (Total: ${totalCalls}):`);
  Object.entries(toolUsage)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 6)
    .forEach(([tool, count]) => {
      const pct = ((count / totalCalls) * 100).toFixed(1);
      console.log(`  ${tool.padEnd(20)} ${count.toString().padStart(4)} (${pct}%)`);
    });
  
  console.log('\nInsights Generated:');
  insights.forEach(i => {
    const icon = {progress: '📈', habit: '🔁', pattern: '🔄', anomaly: '⚠️'}[i.type] || '•';
    console.log(`\n${icon} [${i.type.toUpperCase()}] ${i.description}`);
    console.log(`   Confidence: ${(i.confidence * 100).toFixed(0)}%`);
  });
}
main();
