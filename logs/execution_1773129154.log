      expect(recent).toBe(10); // Base 10 for h=0
      
      // Just passed 1 day (25 hours ago = 1 day + 1 hour)
      // h=0: constantTimeGTE(25, 0) = 1, bonus += 10
      // h=24: constantTimeGTE(25, 24) = 1, bonus += 10
      // Total: 20
      const oneDay = calculator.calculateTimeBonus(now - 25 * 60 * 60 * 1000);
      expect(oneDay).toBe(20);
      
      // 2 days old (49 hours ago)
