/**
 * Geometry Plotter
 * A tool for creating and exporting geometric shapes
 */
class GeometryPlotter {
    constructor() {
        this.shapes = [];
        this.selectedId = null;
        this.currentTool = 'select';
        this.isDragging = false;
        this.isResizing = false;
        this.dragStart = { x: 0, y: 0 };
        this.resizeHandle = null;
        this.history = [];
        this.shapeCounter = 0;
        
        this.canvas = document.getElementById('canvas');
        this.shapesGroup = document.getElementById('shapes');
        this.layerList = document.getElementById('layer-list');
        this.propertiesPanel = document.getElementById('properties');
        
        this.init();
    }
    
    init() {
        this.setupCanvas();
        this.setupEvents();
        this.updateLayerList();
    }
    
    setupCanvas() {
        const resize = () => {
            const container = this.canvas.parentElement;
            const rect = container.getBoundingClientRect();
            this.canvas.setAttribute('width', rect.width);
            this.canvas.setAttribute('height', rect.height);
            this.canvas.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
        };
        resize();
        window.addEventListener('resize', resize);
    }
    
    setupEvents() {
        // Canvas events
        this.canvas.addEventListener('mousedown', (e) => this.onMouseDown(e));
        this.canvas.addEventListener('mousemove', (e) => this.onMouseMove(e));
        this.canvas.addEventListener('mouseup', (e) => this.onMouseUp(e));
        
        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'z') this.undo();
            if (e.key === 'Delete' && this.selectedId) this.deleteShape(this.selectedId);
        });
    }
    
    getMousePos(e) {
        const rect = this.canvas.getBoundingClientRect();
        return {
            x: e.clientX - rect.left,
            y: e.clientY - rect.top
        };
    }
    
    setTool(tool) {
        this.currentTool = tool;
        document.querySelectorAll('.shape-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.tool === tool);
        });
    }
    
    onMouseDown(e) {
        const pos = this.getMousePos(e);
        
        if (this.currentTool === 'select') {
            // Check for resize handle first
            const handle = e.target.closest('.resize-handle');
            if (handle) {
                this.isResizing = true;
                this.resizeHandle = handle.dataset.handle;
                this.dragStart = pos;
                return;
            }
            
            // Check for shape selection
            const shapeEl = e.target.closest('.shape');
            if (shapeEl) {
                this.selectShape(shapeEl.dataset.id);
                this.isDragging = true;
                this.dragStart = pos;
            } else {
                this.selectShape(null);
            }
        } else {
            this.createShape(this.currentTool, pos);
        }
    }
    
    onMouseMove(e) {
        if (!this.isDragging && !this.isResizing) return;
        
        const pos = this.getMousePos(e);
        const dx = pos.x - this.dragStart.x;
        const dy = pos.y - this.dragStart.y;
        
        if (this.isDragging && this.selectedId) {
            const shape = this.getShape(this.selectedId);
            if (shape) {
                shape.x += dx;
                shape.y += dy;
                this.dragStart = pos;
                this.render();
                this.updateProperties();
            }
        } else if (this.isResizing && this.selectedId) {
            this.resizeShape(dx, dy);
            this.dragStart = pos;
        }
    }
    
    onMouseUp(e) {
        this.isDragging = false;
        this.isResizing = false;
        this.resizeHandle = null;
    }
    
    createShape(type, pos) {
        this.saveHistory();
        this.shapeCounter++;
        const id = `shape_${this.shapeCounter}`;
        
        const baseShape = {
            id,
            type,
            x: pos.x,
            y: pos.y,
            fill: '#3498db',
            stroke: '#2980b9',
            strokeWidth: 2,
            opacity: 1
        };
        
        let shape;
        switch (type) {
            case 'rect':
                shape = { 
                    ...baseShape, 
                    x: pos.x - 50, 
                    y: pos.y - 35,
                    width: 100, 
                    height: 70, 
                    rx: 0 
                };
                break;
            case 'circle':
                shape = { 
                    ...baseShape, 
                    x: pos.x - 50, 
                    y: pos.y - 50,
                    r: 50 
                };
                break;
            case 'ellipse':
                shape = { 
                    ...baseShape, 
                    x: pos.x - 60, 
                    y: pos.y - 40,
                    rx: 60, 
                    ry: 40 
                };
                break;
            case 'polygon':
                shape = { 
                    ...baseShape, 
                    x: pos.x - 60, 
                    y: pos.y - 60,
                    sides: 5, 
                    r: 60 
                };
                break;
            case 'line':
                shape = { 
                    ...baseShape, 
                    fill: 'none',
                    x2: pos.x + 100, 
                    y2: pos.y 
                };
                break;
        }
        
        this.shapes.push(shape);
        this.render();
        this.selectShape(id);
        this.updateLayerList();
    }
    
    getShape(id) {
        return this.shapes.find(s => s.id === id);
    }
    
    selectShape(id) {
        this.selectedId = id;
        this.render();
        this.updateLayerList();
        this.updateProperties();
    }
    
    deleteShape(id) {
        this.saveHistory();
        this.shapes = this.shapes.filter(s => s.id !== id);
        if (this.selectedId === id) this.selectedId = null;
        this.render();
        this.updateLayerList();
        this.updateProperties();
    }
    
    resizeShape(dx, dy) {
        const shape = this.getShape(this.selectedId);
        if (!shape) return;
        
        switch (shape.type) {
            case 'rect':
                if (this.resizeHandle === 'se') {
                    shape.width = Math.max(10, shape.width + dx);
                    shape.height = Math.max(10, shape.height + dy);
                }
                break;
            case 'circle':
                if (this.resizeHandle === 'se') {
                    shape.r = Math.max(5, shape.r + Math.min(dx, dy) * 0.5);
                }
                break;
            case 'ellipse':
                if (this.resizeHandle === 'se') {
                    shape.rx = Math.max(5, shape.rx + dx * 0.5);
                    shape.ry = Math.max(5, shape.ry + dy * 0.5);
                }
                break;
            case 'line':
                if (this.resizeHandle === 'end') {
                    shape.x2 += dx;
                    shape.y2 += dy;
                }
                break;
        }
        this.render();
        this.updateProperties();
    }
    
    updateLayerList() {
        if (!this.shapes.length) {
            this.layerList.innerHTML = '<p style="color: #666; padding: 20px; text-align: center;">No shapes</p>';
            return;
        }
        
        this.layerList.innerHTML = this.shapes.slice().reverse().map(shape => {
            const isSelected = shape.id === this.selectedId;
            const thumbColor = shape.fill === 'none' ? shape.stroke : shape.fill;
            return `
                <div class="layer-item ${isSelected ? 'selected' : ''}" onclick="plotter.selectShape('${shape.id}')">
                    <div class="layer-thumb" style="background: ${thumbColor}"></div>
                    <span class="layer-name">${shape.type} ${shape.id.split('_')[1]}</span>
                    <button class="delete-btn" onclick="event.stopPropagation(); plotter.deleteShape('${shape.id}')">×</button>
                </div>
            `;
        }).join('');
    }
    
    updateProperties() {
        if (!this.selectedId) {
            this.propertiesPanel.innerHTML = '<p style="color: #666; text-align: center; padding: 40px 0;">Select a shape to edit</p>';
            return;
        }
        
        const shape = this.getShape(this.selectedId);
        const isLine = shape.type === 'line';
        
        this.propertiesPanel.innerHTML = `
            <div class="prop-group">
                <label>Type</label>
                <input type="text" value="${shape.type}" disabled style="opacity: 0.5;">
            </div>
            <div class="prop-group">
                <label>Position</label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                    <div>
                        <label style="font-size: 10px;">X</label>
                        <input type="number" value="${Math.round(shape.x)}" 
                               onchange="plotter.updateShape('${shape.id}', {x: parseFloat(this.value)})">
                    </div>
                    <div>
                        <label style="font-size: 10px;">Y</label>
                        <input type="number" value="${Math.round(shape.y)}" 
                               onchange="plotter.updateShape('${shape.id}', {y: parseFloat(this.value)})">
                    </div>
                </div>
            </div>
            ${!isLine ? `
            <div class="prop-group">
                <label>Fill Color</label>
                <input type="color" value="${shape.fill}" 
                       onchange="plotter.updateShape('${shape.id}', {fill: this.value})">
            </div>` : ''}
            <div class="prop-group">
                <label>Stroke Color</label>
                <input type="color" value="${shape.stroke}" 
                       onchange="plotter.updateShape('${shape.id}', {stroke: this.value})">
            </div>
            <div class="prop-group">
                <label>Stroke Width <span class="prop-value">${shape.strokeWidth}px</span></label>
                <input type="range" min="0" max="10" value="${shape.strokeWidth}" 
                       onchange="plotter.updateShape('${shape.id}', {strokeWidth: parseInt(this.value)})">
            </div>
            <div class="prop-group">
                <label>Opacity <span class="prop-value">${(shape.opacity * 100).toFixed(0)}%</span></label>
                <input type="range" min="0" max="1" step="0.1" value="${shape.opacity}" 
                       onchange="plotter.updateShape('${shape.id}', {opacity: parseFloat(this.value)})">
            </div>
            ${this.getSpecificControls(shape)}
            <div class="prop-group" style="margin-top: 24px;">
                <button class="btn" style="width: 100%;" onclick="plotter.deleteShape('${shape.id}')">Delete Shape</button>
            </div>
        `;
    }
    
    getSpecificControls(shape) {
        switch (shape.type) {
            case 'rect':
                return `
                    <div class="prop-group">
                        <label>Size</label>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                            <div>
                                <label style="font-size: 10px;">Width</label>
                                <input type="number" value="${Math.round(shape.width)}" 
                                       onchange="plotter.updateShape('${shape.id}', {width: parseFloat(this.value)})">
                            </div>
                            <div>
                                <label style="font-size: 10px;">Height</label>
                                <input type="number" value="${Math.round(shape.height)}" 
                                       onchange="plotter.updateShape('${shape.id}', {height: parseFloat(this.value)})">
                            </div>
                        </div>
                    </div>
                    <div class="prop-group">
                        <label>Corner Radius <span class="prop-value">${shape.rx}px</span></label>
                        <input type="range" min="0" max="50" value="${shape.rx}" 
                               onchange="plotter.updateShape('${shape.id}', {rx: parseInt(this.value)})">
                    </div>`;
            case 'circle':
                return `
                    <div class="prop-group">
                        <label>Radius <span class="prop-value">${shape.r}px</span></label>
                        <input type="range" min="5" max="200" value="${shape.r}" 
                               onchange="plotter.updateShape('${shape.id}', {r: parseInt(this.value)})">
                    </div>`;
            case 'ellipse':
                return `
                    <div class="prop-group">
                        <label>Radius X <span class="prop-value">${shape.rx}px</span></label>
                        <input type="range" min="5" max="200" value="${shape.rx}" 
                               onchange="plotter.updateShape('${shape.id}', {rx: parseInt(this.value)})">
                    </div>
                    <div class="prop-group">
                        <label>Radius Y <span class="prop-value">${shape.ry}px</span></label>
                        <input type="range" min="5" max="200" value="${shape.ry}" 
                               onchange="plotter.updateShape('${shape.id}', {ry: parseInt(this.value)})">
                    </div>`;
            case 'polygon':
                return `
                    <div class="prop-group">
                        <label>Sides <span class="prop-value">${shape.sides}</span></label>
                        <input type="range" min="3" max="12" value="${shape.sides}" 
                               onchange="plotter.updateShape('${shape.id}', {sides: parseInt(this.value)}); plotter.render()">
                    </div>
                    <div class="prop-group">
                        <label>Radius <span class="prop-value">${shape.r}px</span></label>
                        <input type="range" min="10" max="200" value="${shape.r}" 
                               onchange="plotter.updateShape('${shape.id}', {r: parseInt(this.value)})">
                    </div>`;
            case 'line':
                return `
                    <div class="prop-group">
                        <label>End Point</label>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                            <div>
                                <label style="font-size: 10px;">X2</label>
                                <input type="number" value="${Math.round(shape.x2)}" 
                                       onchange="plotter.updateShape('${shape.id}', {x2: parseFloat(this.value)})">
                            </div>
                            <div>
                                <label style="font-size: 10px;">Y2</label>
                                <input type="number" value="${Math.round(shape.y2)}" 
                                       onchange="plotter.updateShape('${shape.id}', {y2: parseFloat(this.value)})">
                            </div>
                        </div>
                    </div>`;
            default:
                return '';
        }
    }
    
    updateShape(id, updates) {
        const shape = this.getShape(id);
        if (shape) {
            Object.assign(shape, updates);
            this.render();
            this.updateLayerList();
            this.updateProperties();
        }
    }
    
    render() {
        this.shapesGroup.innerHTML = this.shapes.map(s => this.renderShape(s)).join('');
    }
    
    renderShape(shape) {
        const isSelected = shape.id === this.selectedId;
        let svg = '';
        const renderHandle = (x, y, handle) => 
            `<circle class="resize-handle" data-id="${shape.id}" data-handle="${handle}" 
                     cx="${x}" cy="${y}" r="5" fill="#e94560" stroke="#fff" stroke-width="2"/>`;
        
        const style = `fill="${shape.fill}" stroke="${shape.stroke}" stroke-width="${shape.strokeWidth}" opacity="${shape.opacity}"`;
        
        switch (shape.type) {
            case 'rect':
                svg = `<rect class="shape ${isSelected ? 'selected' : ''}" data-id="${shape.id}"
                            x="${shape.x}" y="${shape.y}" width="${shape.width}" height="${shape.height}" rx="${shape.rx}" ${style}/>`;
                if (isSelected) {
                    svg += renderHandle(shape.x + shape.width, shape.y + shape.height, 'se');
                }
                break;
            case 'circle':
                const cx = shape.x + shape.r;
                const cy = shape.y + shape.r;
                svg = `<circle class="shape ${isSelected ? 'selected' : ''}" data-id="${shape.id}"
                              cx="${cx}" cy="${cy}" r="${shape.r}" ${style}/>`;
                if (isSelected) {
                    svg += renderHandle(cx + shape.r * 0.7, cy + shape.r * 0.7, 'se');
                }
                break;
            case 'ellipse':
                const ecx = shape.x + shape.rx;
                const ecy = shape.y + shape.ry;
                svg = `<ellipse class="shape ${isSelected ? 'selected' : ''}" data-id="${shape.id}"
                               cx="${ecx}" cy="${ecy}" rx="${shape.rx}" ry="${shape.ry}" ${style}/>`;
                if (isSelected) {
                    svg += renderHandle(ecx + shape.rx * 0.7, ecy + shape.ry * 0.7, 'se');
                }
                break;
            case 'polygon':
                const points = this.calculatePolygonPoints(shape.x + shape.r, shape.y + shape.r, shape.r, shape.sides);
                svg = `<polygon class="shape ${isSelected ? 'selected' : ''}" data-id="${shape.id}"
                               points="${points}" ${style}/>`;
                if (isSelected) {
                    svg += renderHandle(shape.x + shape.r, shape.y, 'se');
                }
                break;
            case 'line':
                svg = `<line class="shape ${isSelected ? 'selected' : ''}" data-id="${shape.id}"
                            x1="${shape.x}" y1="${shape.y}" x2="${shape.x2}" y2="${shape.y2}" ${style}/>`;
                if (isSelected) {
                    svg += renderHandle(shape.x2, shape.y2, 'end');
                }
                break;
        }
        return svg;
    }
    
    calculatePolygonPoints(cx, cy, r, sides) {
        const points = [];
        for (let i = 0; i < sides; i++) {
            const angle = (i * 2 * Math.PI / sides) - Math.PI / 2;
            const x = cx + r * Math.cos(angle);
            const y = cy + r * Math.sin(angle);
            points.push(`${x},${y}`);
        }
        return points.join(' ');
    }
    
    saveHistory() {
        this.history.push(JSON.parse(JSON.stringify(this.shapes)));
        if (this.history.length > 20) this.history.shift();
    }
    
    undo() {
        if (this.history.length > 0) {
            this.shapes = this.history.pop();
            this.selectedId = null;
            // Update counter
            const maxId = this.shapes.reduce((max, s) => {
                const num = parseInt(s.id.split('_')[1]) || 0;
                return Math.max(max, num);
            }, 0);
            this.shapeCounter = maxId;
            this.render();
            this.updateLayerList();
            this.updateProperties();
        }
    }
    
    clear() {
        if (this.shapes.length === 0) return;
        this.saveHistory();
        this.shapes = [];
        this.selectedId = null;
        this.render();
        this.updateLayerList();
        this.updateProperties();
    }
    
    exportSVG() {
        const width = this.canvas.getAttribute('width');
        const height = this.canvas.getAttribute('height');
        const shapes = this.shapes.map(s => this.renderShapeForExport(s)).join('\n  ');
        
        const svg = `<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="${width}" height="${height}" viewBox="0 0 ${width} ${height}">
  <!-- Generated by GeoPlotter -->
  <rect width="100%" height="100%" fill="#ffffff"/>
  ${shapes}
</svg>`;
        
        const blob = new Blob([svg], { type: 'image/svg+xml' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `geoplotter_${new Date().toISOString().slice(0,10)}_${Date.now()}.svg`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }
    
    renderShapeForExport(shape) {
        const style = `fill="${shape.fill}" stroke="${shape.stroke}" stroke-width="${shape.strokeWidth}" opacity="${shape.opacity}"`;
        
        switch (shape.type) {
            case 'rect':
                return `<rect x="${shape.x}" y="${shape.y}" width="${shape.width}" height="${shape.height}" rx="${shape.rx}" ${style}/>`;
            case 'circle':
                const cx = shape.x + shape.r;
                const cy = shape.y + shape.r;
                return `<circle cx="${cx}" cy="${cy}" r="${shape.r}" ${style}/>`;
            case 'ellipse':
                const ecx = shape.x + shape.rx;
                const ecy = shape.y + shape.ry;
                return `<ellipse cx="${ecx}" cy="${ecy}" rx="${shape.rx}" ry="${shape.ry}" ${style}/>`;
            case 'polygon':
                const points = this.calculatePolygonPoints(shape.x + shape.r, shape.y + shape.r, shape.r, shape.sides);
                return `<polygon points="${points}" ${style}/>`;
            case 'line':
                return `<line x1="${shape.x}" y1="${shape.y}" x2="${shape.x2}" y2="${shape.y2}" ${style}/>`;
            default:
                return '';
        }
    }
}

