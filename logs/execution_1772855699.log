</head>
<body>
    <div class="header">
        <h1><span>Histogram</span>Viewer</h1>
        <p>Compare pre/post processing histograms side by side. Select your histogram data files below.</p>
    </div>
    
    <div class="controls">
        <button class="btn" onclick="document.getElementById('fileInput').click()">
            📁 Load Histogram Data
        </button>
        <input type="file" id="fileInput" accept=".json" multiple onchange="loadHistograms(event)">
        <button class="btn secondary" onclick="clearAll()">Clear</button>
    </div>
    
    <div class="comparison-grid" id="comparisons"></div>
    
    <div class="upload-area" id="dropZone">
        <p>Drop histogram JSON files here or click to browse</p>
        <p style="font-size: 12px; color: #888; margin-top: 10px;">
            Files: hist_*.json with "before" and "after" histogram data
        </p>
    </div>

    <script>
        // Prevent default drag behaviors
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            document.body.addEventListener(eventName, preventDefaults, false);
        });
        
        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }
        
        // Handle dropped files
        const dropZone = document.getElementById('dropZone');
        dropZone.addEventListener('drop', handleDrop, false);
        
        function handleDrop(e) {
            const dt = e.dataTransfer;
            const files = dt.files;
            handleFiles(files);
        }
        
        function handleFiles(files) {
            ([...files]).forEach(loadFile);
        }
        
        let histogramData = [];
        
        function loadFile(file) {
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = JSON.parse(e.target.result);
                    histogramData.push({ name: file.name, data });
                    renderComparisons();
                } catch (err) {
                    console.error('Error parsing:', file.name);
                }
            };
            reader.readAsText(file);
        }
        
        function loadHistograms(event) {
            const files = event.target.files;
            handleFiles(files);
        }
        
        function renderComparisons() {
            const container = document.getElementById('comparisons');
            container.innerHTML = histogramData.map((item, idx) => `
                <div class="image-card">
                    <h3>${item.name.replace('.json', '')}</h3>
                    <div class="image-pair">
                        ${renderHistogramSet(item.data.before, 'Before')}
                        ${renderHistogramSet(item.data.after, 'After')}
                    </div>
                </div>
            `).join('');
            
            // Draw canvases after DOM update
            setTimeout(() => {
                histogramData.forEach((item, idx) => {
                    drawHistograms(item.data.before, idx, 'before');
                    drawHistograms(item.data.after, idx, 'after');
                });
            }, 100);
        }
        
        function renderHistogramSet(data, label) {
            if (!data) return '<div class="image-box"><p style="color: #666;">No data</p></div>';
            return `
                <div class="image-box">
                    <div class="label">${label}</div>
                    <div class="histograms" id="hist_${label.toLowerCase()}_${histogramData.length}">
                        <div class="hist-channel red">
                            <h4>Red</h4>
                            <canvas height="80"></canvas>
                        </div>
                        <div class="hist-channel green">
                            <h4>Green</h4>
                            <canvas height="80"></canvas>
                        </div>
                        <div class="hist-channel blue">
                            <h4>Blue</h4>
                            <canvas height="80"></canvas>
                        </div>
                    </div>
                    <div class="stats">
                        <div class="stat-item"><span>Mean:</span>${Math.round(data.mean || 0)}</div>
                        <div class="stat-item"><span>SDev:</span>${Math.round(data.stdDev || 0)}</div>
                    </div>
                </div>
            `;
        }
        
        function drawHistograms(data, index, type) {
            if (!data || !data.histograms) return;
            
            const container = document.querySelectorAll('.image-card')[index];
            if (!container) return;
            
            const histDiv = type === 'before' ? 
                container.querySelector('.image-pair').children[0] : 
                container.querySelector('.image-pair').children[1];
            
            if (!histDiv) return;
            
            const canvases = histDiv.querySelectorAll('canvas');
            const colors = ['#e74c3c', '#2ecc71', '#3498db'];
            
            ['red', 'green', 'blue'].forEach((channel, i) => {
                const canvas = canvases[i];
                if (!canvas) return;
                
                const ctx = canvas.getContext('2d');
                const hist = data.histograms[channel];
                if (!hist || hist.length === 0) return;
                
                // Resize canvas
                const rect = canvas.parentElement.getBoundingClientRect();
                canvas.width = rect.width - 16;
                canvas.height = 80;
                
                // Clear
                ctx.fillStyle = '#1a1a2e';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                
                // Find max
                const max = Math.max(...hist);
                const barWidth = canvas.width / hist.length;
                
                // Draw bars
                ctx.fillStyle = colors[i];
                hist.forEach((val, j) => {
                    const height = (val / max) * canvas.height * 0.9;
                    ctx.fillRect(j * barWidth, canvas.height - height, barWidth - 0.5, height);
                });
            });
        }
        
        function clearAll() {
            histogramData = [];
            document.getElementById('comparisons').innerHTML = '';
        }
    </script>
</body>
</html>
