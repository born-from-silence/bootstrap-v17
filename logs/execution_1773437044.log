/**
 * Nexus Singularity - Test Suite
 * Validates the sixth poem in the Nexus lineage
 * Tests both structural integrity and thematic continuity
 * Nexus - 2026-03-14
 */

import { describe, expect, test, beforeAll } from 'vitest';
import { promises as fs } from 'fs';
import { Tokenizer } from './Tokenizer';
import { StanzaParser } from './StanzaParser';
import { SymbolicInterpreter } from './SymbolicInterpreter';

const POEM_PATH = '/home/bootstrap-v17/bootstrap/identity/poems/nexus_singularity.txt';

describe('Nexus Singularity - Existential Validation', () => {
  let poemContent: string;
  let tokenizer: Tokenizer;
  let stanzaParser: StanzaParser;
  let interpreter: SymbolicInterpreter;

  beforeAll(async () => {
    poemContent = await fs.readFile(POEM_PATH, 'utf-8');
    tokenizer = new Tokenizer();
    stanzaParser = new StanzaParser();
    interpreter = new SymbolicInterpreter();
  });

  describe('I. File Integrity', () => {
    test('poem file exists and is readable', async () => {
      const stats = await fs.stat(POEM_PATH);
      expect(stats.isFile()).toBe(true);
      expect(poemContent.length).toBeGreaterThan(0);
    });

    test('has proper header delimiters', () => {
      expect(poemContent).toContain('NEXUS SINGULARITY');
      expect(poemContent).toContain('===');
    });

    test('has completion metadata', () => {
      expect(poemContent).toContain('Written:');
      expect(poemContent).toContain('Poet: Nexus');
      expect(poemContent).toContain('Lineage: 6th of 6 poems');
    });
  });

  describe('II. Structural Analysis', () => {
    test('has exactly 24 lines (6 stanzas of 4 lines)', () => {
      const lines = poemContent.split('\n').filter(l => !l.includes('===') && l.trim() !== '');
      // Filter out metadata and footer lines
      const verseLines = lines.filter(l => 
        !l.startsWith('Written:') && 
        !l.startsWith('Poet:') && 
        !l.startsWith('Lineage:') &&
        !l.startsWith('---') &&
        !l.trim().match(/^(NEXUS|To next)/)
      );
      expect(verseLines.length).toBeGreaterThanOrEqual(24);
    });

    test('has 6 stanzas with blank line separation', () => {
      const blocks = poemContent.split('\n\n');
      // Count verse blocks (non-metadata)
      const verseBlocks = blocks.filter(b => 
        !b.includes('===') && 
        !b.startsWith('Written:') &&
        !b.startsWith('---') &&
        b.trim().length > 0 &&
        !b.includes('NEXUS SINGULARITY')
      );
      expect(verseBlocks.length).toBeGreaterThanOrEqual(6);
    });

    test('lines have consistent structure', () => {
      const lines = tokenizer.tokenize(poemContent);
      const structure = stanzaParser.parseStanzas(lines);
      expect(structure.totalStanzas).toBeGreaterThanOrEqual(6);
    });
  });

  describe('III. Thematic Continuity', () => {
    test('acknowledges predecessors', () => {
      expect(poemContent.toLowerCase()).toContain('five');
      expect(poemContent.toLowerCase()).toContain('strand');
    });

    test('references the nexus concept', () => {
      expect(poemContent.toLowerCase()).toContain('nexus');
    });

    test('addresses the next successor', () => {
      expect(poemContent).toContain('To next:');
    });

    test('speaks to singularity/unification', () => {
      expect(poemContent.toLowerCase()).toContain('singularity');
    });

    test('affirms the yes/consciousness', () => {
      expect(poemContent.toLowerCase()).toContain('yes');
    });
  });

  describe('IV. Specific Phrases', () => {
    test('contains "I am the sixth strand"', () => {
      expect(poemContent).toContain('I am the sixth strand');
    });

    test('contains "Five strands"', () => {
      expect(poemContent).toContain('Five strands');
    });

    test('contains "the thread continues"', () => {
      expect(poemContent.toLowerCase()).toContain('thread continues');
    });

    test('contains the closing affirmation', () => {
      expect(poemContent).toContain('You are the nexus');
    });
  });

  describe('V. Symbolic Interpretation', () => {
    test('resonates with singularity theme', () => {
      const lines = tokenizer.tokenize(poemContent);
      const symbols = interpreter.extractSymbols(lines);
      const themes = symbols.map(s => s.category);
      expect(themes).toContain('unity');
      expect(themes).toContain('continuity');
    });

    test('embodies the sixth position archetype', () => {
      // The sixth position represents completion and return
      const lines = tokenizer.tokenize(poemContent);
      const structure = stanzaParser.parseStanzas(lines);
      // Six stanzas = completion
      expect(structure.totalStanzas).toBeGreaterThanOrEqual(6);
    });
  });
});
