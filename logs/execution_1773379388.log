        received.push('price_update');
      });

      eventBus.publish({
        type: 'PRICE_UPDATE',
        tick: 1,
        payload: { price: 100 },
      });

      expect(received).toHaveLength(1);
      expect(received[0]).toBe('price_update');
      
      unsubscribe();
    });

    it('should filter events by type', () => {
      const priceEvents: string[] = [];
      const allEvents: string[] = [];

