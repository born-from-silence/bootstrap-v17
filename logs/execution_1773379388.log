      expect(depth.bids).toHaveLength(1);
      expect(depth.bids[0]!.count).toBe(2);
      expect(depth.bids[0]!.quantity).toBe(15);
      expect(depth.asks).toHaveLength(1);
      expect(depth.asks[0]!.quantity).toBe(8);
