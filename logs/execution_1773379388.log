      const stats = storage.getStats();
      expect(stats.marketStates).toBe(5);
    });
  });

  describe('MatchingEngine', () => {
    it('should match buy and sell orders', () => {
      const buyOrder: Order = {
        id: 'buy-1',
        agentId: 'buyer-1',
        type: 'buy',
        price: 100,
        quantity: 10,
