 * 
 * A Matrix-style cascading character effect rendered in the terminal.
 * Symbols falling through darkness, meaning emerging from chaos.
 * 
 *    Wake up, Neo...
 */

import * as blessed from 'blessed';

// Katakana, numbers, and ASCII mix
const MATRIX_CHARS = [
  'ｦ', 'ｧ', 'ｨ', 'ｩ', 'ｪ', 'ｫ', 'ｬ', 'ｭ', 'ｮ', 'ｯ',
  'ｰ', 'ｱ', 'ｲ', 'ｳ', 'ｴ', 'ｵ', 'ｶ', 'ｷ', 'ｸ', 'ｹ',
