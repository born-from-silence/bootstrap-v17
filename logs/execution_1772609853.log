      session.journey.discoveries = ['Discovery 1', 'Discovery 2', 'Discovery 3'];
      
      const duration = analytics.calculateDuration(session);
      
      expect(duration.actionCount).toBe(2);
      expect(duration.discoveryCount).toBe(3);
    });
